{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "component.contract.schema.json",
  "title": "Component Contract",
  "description": "Schema for ui/components/*/*.contract.json files",
  "type": "object",
  "required": [
    "name",
    "layer"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9]*$",
      "description": "Component name — PascalCase preferred, lowercase accepted for legacy components"
    },
    "layer": {
      "type": "string",
      "enum": [
        "primitive",
        "compound",
        "composer"
      ],
      "description": "Component abstraction layer"
    },
    "anatomy": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "maxItems": 24,
      "description": "Named structural parts. First item must be 'root'."
    },
    "variants": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "minItems": 1
      },
      "description": "Variant dimensions and their allowed values"
    },
    "states": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Visual/interaction states. Must include 'default'."
    },
    "slots": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "required"
        ],
        "additionalProperties": false,
        "properties": {
          "required": {
            "type": "boolean"
          },
          "selector": {
            "type": "string",
            "description": "CSS selector string, e.g. [data-slot=\"trigger\"]"
          }
        }
      },
      "description": "Named slot anchors with their DOM selector and required status"
    },
    "a11y": {
      "type": "object",
      "required": [
        "role",
        "labeling",
        "keyboard"
      ],
      "additionalProperties": false,
      "properties": {
        "role": {
          "type": "string",
          "description": "Primary ARIA role"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "All ARIA roles when multiple are used"
        },
        "labeling": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "ARIA labeling attributes used (aria-label, aria-labelledby, etc.)"
        },
        "keyboard": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/keyboardEntry"
          },
          "description": "Keyboard interaction map"
        },
        "apgPattern": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "screenReader": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Screen reader announcements or live region behavior"
        }
      }
    },
    "tokens": {
      "type": "object",
      "description": "Design tokens keyed by anatomy part. Values may be legacy string arrays, structured resolution maps, literal maps, or nested token maps.",
      "additionalProperties": {
        "$ref": "#/definitions/tokenValue"
      }
    },
    "props": {
      "type": "object",
      "description": "Prop API surfaces extracted from TypeScript source",
      "additionalProperties": {
        "type": "object",
        "required": [
          "members"
        ],
        "additionalProperties": false,
        "properties": {
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/propMember"
            }
          }
        }
      }
    },
    "channels": {
      "type": "object",
      "description": "Controlled/uncontrolled prop pairings",
      "additionalProperties": {
        "$ref": "#/definitions/controlledChannel"
      }
    },
    "types": {
      "type": "object",
      "description": "Named type aliases referenced by props",
      "additionalProperties": {
        "type": "object",
        "required": [
          "kind"
        ],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "union",
              "enum",
              "alias"
            ]
          },
          "values": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "alias": {
            "type": "string"
          }
        }
      }
    },
    "stateMachine": {
      "type": "object",
      "required": [
        "transitions"
      ],
      "additionalProperties": false,
      "description": "Declarative state machine for complex interaction patterns",
      "properties": {
        "transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "event",
              "to"
            ],
            "additionalProperties": false,
            "properties": {
              "event": {
                "type": "string"
              },
              "from": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "to": {
                "type": "string"
              },
              "guard": {
                "type": "string"
              },
              "effect": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "focus": {
      "type": "object",
      "additionalProperties": false,
      "description": "Focus management contract.",
      "properties": {
        "description": {
          "type": "string"
        },
        "strategy": {
          "type": "string",
          "enum": [
            "trap",
            "roving",
            "auto",
            "manual",
            "none"
          ]
        },
        "orientation": {
          "type": "string",
          "enum": [
            "horizontal",
            "vertical",
            "both"
          ]
        },
        "initialFocus": {
          "type": "string"
        },
        "returnFocus": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "boolean"
            }
          ]
        },
        "wrap": {
          "type": "boolean"
        },
        "scrollLock": {
          "type": "boolean"
        }
      }
    },
    "dismissal": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "escape",
              "outsideClick",
              "overlayClick",
              "blur",
              "routeChange",
              "triggerReclick",
              "userDismiss",
              "selection"
            ]
          },
          "description": "Legacy list of dismissal trigger names."
        },
        {
          "$ref": "#/definitions/dismissalContract"
        }
      ],
      "description": "Triggers that close or dismiss this component."
    },
    "motion": {
      "type": "object",
      "additionalProperties": false,
      "description": "Animation contract.",
      "properties": {
        "description": {
          "type": "string"
        },
        "transitions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/motionTransition"
          }
        },
        "reducedMotion": {
          "type": "string",
          "enum": [
            "respect",
            "disable",
            "reduce",
            "ignore"
          ]
        },
        "reducedMotionStrategy": {
          "type": "string"
        }
      }
    },
    "portal": {
      "type": "object",
      "required": [
        "enabled"
      ],
      "additionalProperties": false,
      "description": "Portal / overlay rendering contract",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "defaultTarget": {
          "type": "string"
        },
        "positioning": {
          "type": "string",
          "enum": [
            "anchored",
            "centered",
            "fixed",
            "absolute",
            "none"
          ]
        },
        "layering": {
          "type": "string",
          "enum": [
            "modal",
            "popover",
            "dialog",
            "tooltip",
            "menu",
            "toast",
            "auto",
            "none"
          ]
        },
        "collision": {
          "type": "string"
        },
        "backdrop": {
          "type": "boolean"
        }
      }
    },
    "relationships": {
      "type": "array",
      "description": "Declarative ARIA relationships between anatomy parts",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "attribute"
        ],
        "additionalProperties": false,
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "attribute": {
            "type": "string"
          },
          "when": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "ssr": {
      "type": "object",
      "required": [
        "hydrateOn"
      ],
      "additionalProperties": false,
      "properties": {
        "hydrateOn": {
          "type": "string",
          "enum": [
            "interaction",
            "none",
            "load"
          ]
        }
      }
    },
    "rtl": {
      "type": "object",
      "required": [
        "flipIcon"
      ],
      "additionalProperties": false,
      "properties": {
        "flipIcon": {
          "type": "boolean"
        }
      }
    },
    "schemaVersion": {
      "type": "string",
      "description": "Contract schema version."
    },
    "description": {
      "type": "string",
      "description": "Brief human-readable summary of the component purpose."
    },
    "form": {
      "$ref": "#/definitions/formContract"
    },
    "events": {
      "type": "object",
      "description": "Structured callback/event signatures exposed by the component.",
      "additionalProperties": {
        "$ref": "#/definitions/eventSignature"
      }
    },
    "usage": {
      "$ref": "#/definitions/usage"
    },
    "a2ui": {
      "$ref": "#/definitions/a2uiContract",
      "description": "Agent-facing authoring metadata."
    }
  },
  "definitions": {
    "tokenResolution": {
      "type": "object",
      "required": [
        "resolvesTo",
        "fallback"
      ],
      "additionalProperties": false,
      "properties": {
        "resolvesTo": {
          "type": "string",
          "description": "Semantic token path (no -- prefix), e.g. semantic.color.action.background.primary"
        },
        "fallback": {
          "type": "string",
          "description": "Literal CSS fallback value when token sheet is not loaded"
        },
        "property": {
          "type": "string",
          "description": "CSS property this token is applied to, e.g. background-color"
        },
        "layer": {
          "type": "string",
          "enum": [
            "core",
            "semantic",
            "brand",
            "density"
          ],
          "description": "Token layer this resolves from"
        }
      }
    },
    "propMember": {
      "type": "object",
      "required": [
        "name",
        "type",
        "description"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "default": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            }
          ]
        },
        "nodeKind": {
          "type": "string",
          "enum": [
            "node-ref",
            "icon-ref"
          ],
          "description": "Disambiguates ReactNode: a composed subtree vs a named icon"
        }
      }
    },
    "controlledChannel": {
      "type": "object",
      "required": [
        "value",
        "onChange"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": "string",
          "description": "Controlled value prop name"
        },
        "onChange": {
          "type": "string",
          "description": "Change handler prop name"
        },
        "defaultValue": {
          "type": "string",
          "description": "Uncontrolled default prop name"
        },
        "enabledBy": {
          "type": "string",
          "description": "Prop that enables this channel"
        },
        "valueType": {
          "type": "string",
          "description": "TypeScript type string for the value"
        },
        "notes": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "literalToken": {
      "type": "object",
      "required": [
        "literal"
      ],
      "additionalProperties": false,
      "description": "Literal CSS value that intentionally does not resolve through another design token.",
      "properties": {
        "literal": {
          "type": "string"
        },
        "property": {
          "type": "string"
        },
        "layer": {
          "type": "string",
          "enum": [
            "core",
            "semantic",
            "brand",
            "density",
            "literal"
          ]
        }
      }
    },
    "tokenValue": {
      "description": "Token value in legacy flat, structured resolution, literal, string, or nested-map form.",
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "anyOf": [
              {
                "$ref": "#/definitions/tokenResolution"
              },
              {
                "$ref": "#/definitions/literalToken"
              },
              {
                "type": "string"
              },
              {
                "$ref": "#/definitions/tokenValue"
              }
            ]
          }
        }
      ]
    },
    "motionTransition": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "trigger": {
          "type": "string"
        },
        "phase": {
          "type": "string",
          "enum": [
            "enter",
            "exit",
            "move",
            "attention"
          ]
        },
        "properties": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "property": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "easing": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "keyboardEntry": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": [
            "key"
          ],
          "additionalProperties": false,
          "properties": {
            "key": {
              "type": "string"
            },
            "when": {
              "type": "string"
            },
            "then": {
              "type": "string"
            },
            "action": {
              "type": "string"
            },
            "mode": {
              "type": "string"
            }
          }
        }
      ]
    },
    "dismissalContract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "triggers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/dismissalTrigger"
          }
        }
      }
    },
    "dismissalTrigger": {
      "type": "object",
      "required": [
        "event"
      ],
      "additionalProperties": false,
      "properties": {
        "event": {
          "type": "string",
          "enum": [
            "escape",
            "overlayClick",
            "outsideClick",
            "blur",
            "routeChange",
            "triggerReclick",
            "userDismiss",
            "selection"
          ]
        },
        "enabledBy": {
          "type": "string"
        },
        "defaultEnabled": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "eventSignature": {
      "type": "object",
      "required": [
        "description"
      ],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "emittedVia": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "payload": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/eventPayloadField"
          }
        },
        "returns": {
          "type": "string"
        },
        "cancelable": {
          "type": "boolean"
        },
        "triggeredBy": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "eventPayloadField": {
      "type": "object",
      "required": [
        "name",
        "type"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "optional": {
          "type": "boolean"
        }
      }
    },
    "formContract": {
      "type": "object",
      "required": [
        "participates"
      ],
      "additionalProperties": false,
      "properties": {
        "participates": {
          "type": "boolean"
        },
        "inputType": {
          "type": "string",
          "enum": [
            "text",
            "number",
            "email",
            "password",
            "search",
            "tel",
            "url",
            "date",
            "time",
            "datetime-local",
            "month",
            "week",
            "color",
            "file",
            "checkbox",
            "radio",
            "select",
            "hidden",
            "combobox",
            "custom"
          ]
        },
        "name": {
          "$ref": "#/definitions/formPropRef"
        },
        "formProp": {
          "$ref": "#/definitions/formPropRef"
        },
        "required": {
          "type": "object",
          "required": [
            "prop"
          ],
          "additionalProperties": false,
          "properties": {
            "prop": {
              "type": "string"
            },
            "constraintValidation": {
              "type": "boolean"
            }
          }
        },
        "serialization": {
          "type": "object",
          "required": [
            "valueType",
            "valueSource"
          ],
          "additionalProperties": false,
          "properties": {
            "valueType": {
              "type": "string"
            },
            "valueSource": {
              "type": "string"
            },
            "omitWhen": {
              "type": "string",
              "enum": [
                "unchecked",
                "empty",
                "disabled",
                "never"
              ]
            },
            "multiple": {
              "type": "boolean"
            }
          }
        },
        "validity": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "model": {
              "type": "string",
              "enum": [
                "native",
                "props",
                "hybrid"
              ]
            },
            "invalidProp": {
              "type": "string"
            },
            "errorMessageProp": {
              "type": "string"
            },
            "errorSurface": {
              "type": "string",
              "enum": [
                "aria-describedby",
                "aria-errormessage",
                "live-region",
                "none"
              ]
            },
            "ariaAttributes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "labeling": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "strategy": {
              "type": "string",
              "enum": [
                "associated-label",
                "self-labeling",
                "wrapped-label"
              ]
            },
            "required": {
              "type": "boolean"
            },
            "via": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "autofill": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "autocomplete": {
              "type": "string"
            },
            "hints": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "formPropRef": {
      "type": "object",
      "required": [
        "prop"
      ],
      "additionalProperties": false,
      "properties": {
        "prop": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "example": {
          "type": "string"
        },
        "hookExample": {
          "type": "string"
        }
      }
    },
    "a2uiContract": {
      "type": "object",
      "required": [
        "category"
      ],
      "additionalProperties": false,
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "form-field",
            "action",
            "display",
            "container",
            "feedback",
            "navigation",
            "overlay",
            "media",
            "animation",
            "content",
            "layout"
          ]
        },
        "usageHints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "children": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowed": {
              "type": "boolean"
            },
            "slot": {
              "type": "string"
            },
            "accepts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "min": {
              "type": "integer",
              "minimum": 0
            },
            "max": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  }
}
