{
  "$schema": "../designTokens.schema.json",
  "motion": {
    "interaction": {
      "press": {
        "duration": {
          "$type": "duration",
          "$value": "{motion.duration.instant}",
          "$description": "Immediate feedback for button presses"
        },
        "easing": {
          "$type": "cubicBezier",
          "$value": "{motion.easing.standard}"
        },
        "scale": {
          "$type": "number",
          "$value": 0.98,
          "$description": "Subtle scale down for press feedback"
        }
      },
      "hover": {
        "duration": {
          "$type": "duration",
          "$value": "{motion.duration.short2}",
          "$description": "Quick hover state transitions"
        },
        "easing": {
          "$type": "cubicBezier",
          "$value": "{motion.easing.quick.enter}"
        }
      },
      "focus": {
        "duration": {
          "$type": "duration",
          "$value": "{motion.duration.short3}",
          "$description": "Focus ring appearance"
        },
        "easing": {
          "$type": "cubicBezier",
          "$value": "{motion.easing.soft.enter}"
        }
      },
      "enter": {
        "duration": {
          "$type": "duration",
          "$value": "{motion.duration.medium1}",
          "$description": "Standard enter animations"
        },
        "easing": {
          "$type": "cubicBezier",
          "$value": "{motion.easing.soft.enter}"
        }
      },
      "exit": {
        "duration": {
          "$type": "duration",
          "$value": "{motion.duration.short3}",
          "$description": "Quick exit animations"
        },
        "easing": {
          "$type": "cubicBezier",
          "$value": "{motion.easing.quick.exit}"
        }
      },
      "modal": {
        "enter": {
          "duration": {
            "$type": "duration",
            "$value": "{motion.duration.medium2}",
            "$description": "Modal entrance - comfortable timing"
          },
          "easing": {
            "$type": "cubicBezier",
            "$value": "{motion.easing.soft.enter}"
          }
        },
        "exit": {
          "duration": {
            "$type": "duration",
            "$value": "{motion.duration.medium1}",
            "$description": "Modal exit - slightly faster"
          },
          "easing": {
            "$type": "cubicBezier",
            "$value": "{motion.easing.soft.exit}"
          }
        }
      },
      "tooltip": {
        "enter": {
          "duration": {
            "$type": "duration",
            "$value": "{motion.duration.short3}",
            "$description": "Quick tooltip appearance"
          },
          "easing": {
            "$type": "cubicBezier",
            "$value": "{motion.easing.quick.enter}"
          },
          "delay": {
            "$type": "duration",
            "$value": "{motion.delay.medium}",
            "$description": "Delay before showing tooltip"
          }
        },
        "exit": {
          "duration": {
            "$type": "duration",
            "$value": "{motion.duration.short1}",
            "$description": "Immediate tooltip disappearance"
          },
          "easing": {
            "$type": "cubicBezier",
            "$value": "{motion.easing.quick.exit}"
          }
        }
      }
    },
    "keyframes": {
      "fadeIn": {
        "$type": "string",
        "$value": "fadeIn",
        "$description": "Standard fade in animation"
      },
      "slideUp": {
        "$type": "string",
        "$value": "slideUp",
        "$description": "Slide up from bottom"
      },
      "scaleIn": {
        "$type": "string",
        "$value": "scaleIn",
        "$description": "Scale in from center"
      },
      "pulse": {
        "$type": "string",
        "$value": "pulse",
        "$description": "Subtle pulse for loading states"
      }
    },
    "stagger": {
      "list": {
        "$type": "duration",
        "$value": "{motion.stagger.sm}",
        "$description": "Stagger for list item animations"
      },
      "card": {
        "$type": "duration",
        "$value": "{motion.stagger.md}",
        "$description": "Stagger for card grid animations"
      },
      "section": {
        "$type": "duration",
        "$value": "{motion.stagger.lg}",
        "$description": "Stagger for section reveals"
      }
    },
    "transition": {
      "scale": {
        "identity": {
          "$type": "number",
          "$value": "{scale.100}",
          "$description": "No-op scale — base / resting state"
        },
        "zoom": {
          "$type": "number",
          "$value": "{scale.105}",
          "$description": "Zoom-in entrance scale"
        },
        "shrink": {
          "$type": "number",
          "$value": "{scale.095}",
          "$description": "Shrink-out exit scale"
        }
      }
    },
    "icon": {
      "scale": {
        "enter": {
          "$type": "number",
          "$value": "{scale.080}",
          "$description": "Icon initial scale when entering (grows to full size)"
        },
        "exit": {
          "$type": "number",
          "$value": "{scale.080}",
          "$description": "Icon final scale when exiting (shrinks from full size)"
        }
      }
    },
    "opacity": {
      "overlay": {
        "light": {
          "$type": "number",
          "$value": 0.6,
          "$description": "Light page-transition overlay opacity"
        },
        "heavy": {
          "$type": "number",
          "$value": 0.9,
          "$description": "Heavy page-transition overlay opacity"
        }
      },
      "content": {
        "default": {
          "$type": "number",
          "$value": 1,
          "$description": "Fully visible content"
        },
        "fade": {
          "$type": "number",
          "$value": 0.7,
          "$description": "Faded content during page transition"
        }
      }
    }
  }
}
