{
  "$schema": "../designTokens.schema.json",
  "control": {
    "size": {
      "sm": {
        "height": {
          "$type": "dimension",
          "$value": "{spacing.size.07}"
        },
        "paddingX": {
          "$type": "dimension",
          "$value": "{spacing.size.03}"
        },
        "paddingY": {
          "$type": "dimension",
          "$value": "{spacing.size.02}"
        }
      },
      "md": {
        "height": {
          "$type": "dimension",
          "$value": "{spacing.size.08}"
        },
        "paddingX": {
          "$type": "dimension",
          "$value": "{spacing.size.04}"
        },
        "paddingY": {
          "$type": "dimension",
          "$value": "{spacing.size.03}"
        }
      },
      "lg": {
        "height": {
          "$type": "dimension",
          "$value": "{spacing.size.09}"
        },
        "paddingX": {
          "$type": "dimension",
          "$value": "{spacing.size.06}"
        },
        "paddingY": {
          "$type": "dimension",
          "$value": "{spacing.size.04}"
        }
      }
    },
    "toggle": {
      "width": {
        "sm": { "$type": "string", "$value": "calc(var(--semantic-control-size-sm-height) + var(--semantic-control-size-sm-paddingX) * 2)", "$description": "ToggleSwitch track width sm (= 32px)" },
        "md": { "$type": "string", "$value": "calc(var(--semantic-control-size-md-height) + var(--semantic-control-size-md-paddingX) * 2)", "$description": "ToggleSwitch track width md (= 48px)" },
        "lg": { "$type": "string", "$value": "calc(var(--semantic-control-size-lg-height) + var(--semantic-control-size-lg-paddingX) * 2)", "$description": "ToggleSwitch track width lg (= 80px)" }
      },
      "thumb": {
        "sm": { "$type": "string", "$value": "calc(var(--semantic-control-size-sm-height) - var(--semantic-control-size-sm-paddingY) * 2)", "$description": "ToggleSwitch thumb size sm (= 20px)" },
        "md": { "$type": "string", "$value": "calc(var(--semantic-control-size-md-height) - var(--semantic-control-size-md-paddingY) * 2)", "$description": "ToggleSwitch thumb size md (= 24px)" },
        "lg": { "$type": "string", "$value": "calc(var(--semantic-control-size-lg-height) - var(--semantic-control-size-lg-paddingY) * 2)", "$description": "ToggleSwitch thumb size lg (= 32px)" }
      }
    }
  }
}
