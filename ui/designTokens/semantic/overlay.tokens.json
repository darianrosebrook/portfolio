{
  "$schema": "../designTokens.schema.json",
  "overlay": {
    "scrimWeak": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [0, 0, 0],
        "alpha": 0.24
      },
      "$extensions": {
        "design.paths.light": "rgba(0,0,0,0.24)",
        "design.paths.dark": "rgba(0,0,0,0.40)"
      },
      "$description": "Weak overlay scrim"
    },
    "scrimMedium": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [0, 0, 0],
        "alpha": 0.4
      },
      "$extensions": {
        "design.paths.light": "rgba(0,0,0,0.40)",
        "design.paths.dark": "rgba(0,0,0,0.60)"
      },
      "$description": "Medium overlay scrim"
    },
    "scrimStrong": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [0, 0, 0],
        "alpha": 0.64
      },
      "$extensions": {
        "design.paths.light": "rgba(0,0,0,0.64)",
        "design.paths.dark": "rgba(0,0,0,0.80)"
      },
      "$description": "Strong overlay scrim"
    },
    "scrimSheet": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [0, 0, 0],
        "alpha": 0.5
      },
      "$extensions": {
        "design.paths.light": "rgba(0,0,0,0.50)",
        "design.paths.dark": "rgba(0,0,0,0.70)"
      },
      "$description": "Backdrop scrim for sheet and drawer components"
    },
    "scrimDialog": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [0, 0, 0],
        "alpha": 0.6
      },
      "$extensions": {
        "design.paths.light": "rgba(0,0,0,0.60)",
        "design.paths.dark": "rgba(0,0,0,0.80)"
      },
      "$description": "Backdrop scrim for dialog and command palette overlays"
    }
  }
}
