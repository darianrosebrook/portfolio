{
  "name": "Tooltip",
  "layer": "primitive",
  "anatomy": [
    "root"
  ],
  "variants": {
    "placement": [
      "top",
      "bottom",
      "left",
      "right",
      "auto"
    ]
  },
  "states": [
    "default",
    "hover",
    "entering",
    "leaving"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"tooltip\"]"
    }
  },
  "a11y": {
    "role": "tooltip",
    "labeling": [
      "aria-describedby"
    ],
    "keyboard": [],
    "apgPattern": "tooltip"
  },
  "tokens": {
    "root": {
      "tooltip.color.background.default": {
        "resolvesTo": "semantic.color.background.inverse",
        "fallback": "#141414",
        "property": "background-color",
        "layer": "semantic"
      },
      "tooltip.color.foreground.default": {
        "resolvesTo": "semantic.color.foreground.inverse",
        "fallback": "#fafafa",
        "property": "color",
        "layer": "semantic"
      },
      "tooltip.color.border.default": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "property": "border-color",
        "layer": "semantic"
      },
      "tooltip.size.padding.y": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "property": "padding",
        "layer": "core"
      },
      "tooltip.size.padding.x": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "padding",
        "layer": "core"
      },
      "tooltip.size.radius.default": {
        "resolvesTo": "core.shape.radius.small",
        "fallback": "4px",
        "property": "border-radius",
        "layer": "core"
      },
      "tooltip.size.maxWidth": {
        "literal": "200px"
      },
      "tooltip.elevation.default": {
        "resolvesTo": "semantic.elevation.surface.floating",
        "fallback": "[object Object]",
        "layer": "semantic"
      },
      "tooltip.typography.fontSize": {
        "resolvesTo": "semantic.typography.caption.01",
        "fallback": "14px",
        "layer": "semantic"
      },
      "tooltip.typography.fontWeight": {
        "resolvesTo": "semantic.typography.font.weight.medium",
        "fallback": "500",
        "layer": "semantic"
      },
      "tooltip.typography.lineHeight": {
        "resolvesTo": "semantic.typography.line.height.tight",
        "fallback": "1.2",
        "property": "line-height",
        "layer": "semantic"
      },
      "tooltip.motion.duration.enter": {
        "resolvesTo": "semantic.motion.interaction.enter.duration",
        "fallback": "250ms",
        "property": "transition-duration",
        "layer": "semantic"
      },
      "tooltip.motion.duration.exit": {
        "resolvesTo": "semantic.motion.interaction.exit.duration",
        "fallback": "167ms",
        "property": "transition-duration",
        "layer": "semantic"
      },
      "tooltip.motion.easing.enter": {
        "resolvesTo": "semantic.motion.interaction.enter.easing",
        "fallback": "cubic-bezier(0, 0, 0.7, 1)",
        "property": "transition-timing-function",
        "layer": "semantic"
      },
      "tooltip.motion.easing.exit": {
        "resolvesTo": "semantic.motion.interaction.exit.easing",
        "fallback": "cubic-bezier(1, 0, 1, 1)",
        "property": "transition-timing-function",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        { "name": "content", "type": "ReactNode", "description": "The tooltip text or rich content shown in the floating panel.", "required": true },
        { "name": "placement", "type": "Placement | undefined", "description": "Preferred placement of the tooltip relative to its trigger. May be overridden by collision detection.", "required": false },
        { "name": "trigger", "type": "TriggerStrategy | undefined", "description": "Interaction that activates the tooltip: hover (default), focus, or manual control.", "required": false },
        { "name": "delay", "type": "number | undefined", "description": "Milliseconds to wait before showing the tooltip on hover. Reduces unintentional activation during pointer travel.", "required": false },
        { "name": "disabled", "type": "boolean | undefined", "description": "Suppresses the tooltip entirely without removing the trigger child from the DOM.", "required": false }
      ]
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "Duration set to 0; tooltip appears/disappears instantly without opacity transition.",
    "transitions": [
      {
        "name": "show",
        "trigger": "visibility=hidden→visible",
        "phase": "enter",
        "properties": [
          "opacity"
        ],
        "duration": "tooltip.motion.duration.enter",
        "easing": "tooltip.motion.easing.enter"
      },
      {
        "name": "hide",
        "trigger": "visibility=visible→hidden",
        "phase": "exit",
        "properties": [
          "opacity"
        ],
        "duration": "tooltip.motion.duration.exit",
        "easing": "tooltip.motion.easing.exit"
      }
    ]
  },
  "focus": {
    "strategy": "none",
    "description": "Tooltip never takes focus — it is non-interactive. The trigger element retains focus throughout the tooltip's lifecycle."
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "positioning": "anchored",
    "layering": "tooltip",
    "collision": "flip-shift"
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape",
        "defaultEnabled": true,
        "description": "WCAG 2.1 SC 1.4.13 — Escape dismisses tooltip without moving focus from the trigger."
      },
      {
        "event": "blur",
        "defaultEnabled": true,
        "description": "Tooltip hides when the trigger loses hover or keyboard focus."
      }
    ]
  },
  "relationships": [
    {
      "from": "trigger",
      "to": "root",
      "attribute": "aria-describedby",
      "when": "visibility=visible",
      "description": "Trigger's aria-describedby points to the tooltip content's id when visible, providing supplemental screen-reader description."
    }
  ],
  "description": "Floating label providing supplemental information about a trigger element on hover or focus.",
  "a2ui": {
    "category": "overlay",
    "usageHints": [
      "Wrap any focusable element as the Tooltip trigger child",
      "Keep tooltip content to a single brief phrase — never include interactive elements",
      "Use placement to control which side the tooltip appears on",
      "Tooltip satisfies WCAG 2.1 SC 1.4.13 — it is dismissible via Escape"
    ],
    "children": {
      "allowed": true,
      "slot": "trigger",
      "accepts": [
        "node-ref"
      ]
    }
  }
}
