{
  "name": "Tooltip",
  "layer": "primitive",
  "anatomy": [
    "root"
  ],
  "variants": {
    "placement": [
      "top",
      "bottom",
      "left",
      "right",
      "auto"
    ]
  },
  "states": [
    "default",
    "hover",
    "entering",
    "leaving"
  ],
  "slots": {},
  "a11y": {
    "role": "tooltip",
    "labeling": [
      "aria-describedby"
    ],
    "keyboard": [],
    "apgPattern": "tooltip"
  },
  "tokens": {
    "root": [
      "tooltip.color.background.default",
      "tooltip.color.foreground.default",
      "tooltip.color.border.default",
      "tooltip.size.padding.y",
      "tooltip.size.padding.x",
      "tooltip.size.radius.default",
      "tooltip.size.maxWidth.value",
      "tooltip.size.maxWidth.unit",
      "tooltip.elevation.default",
      "tooltip.typography.fontSize",
      "tooltip.typography.fontWeight",
      "tooltip.typography.lineHeight",
      "tooltip.motion.duration.enter",
      "tooltip.motion.duration.exit",
      "tooltip.motion.easing.enter",
      "tooltip.motion.easing.exit"
    ]
  },
  "props": {
    "styled": {
      "members": [
        {
          "name": "content",
          "type": "ReactNode",
          "description": "Tooltip content",
          "required": true
        },
        {
          "name": "placement",
          "type": "Placement | undefined",
          "description": "Placement relative to trigger",
          "required": false
        },
        {
          "name": "trigger",
          "type": "TriggerStrategy | undefined",
          "description": "How the tooltip is triggered",
          "required": false
        },
        {
          "name": "delay",
          "type": "number | undefined",
          "description": "Delay before showing (ms)",
          "required": false
        },
        {
          "name": "disabled",
          "type": "boolean | undefined",
          "description": "Whether tooltip is disabled",
          "required": false
        }
      ]
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  }
}
