{
  "name": "AnimatedCard",
  "layer": "primitive",
  "anatomy": [
    "root",
    "animatedCard",
    "hoverable",
    "cardImage",
    "cardTitle",
    "cardOverlay",
    "cardImageWrapper"
  ],
  "variants": {
    "as": [
      "h1",
      "h2",
      "h3",
      "h4",
      "h5",
      "h6"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus"
  ],
  "slots": {},
  "a11y": {
    "role": "generic",
    "labeling": [],
    "keyboard": [],
    "apgPattern": null
  },
  "tokens": {},
  "props": {
    "styled": {
      "members": [
        {
          "name": "as",
          "type": "\"article\" | \"div\" | \"li\" | \"a\" | undefined",
          "description": "Element type to render",
          "required": false
        },
        {
          "name": "duration",
          "type": "number | undefined",
          "description": "Duration of entry animation in seconds",
          "required": false
        },
        {
          "name": "delay",
          "type": "number | undefined",
          "description": "Delay before animation starts in seconds",
          "required": false
        },
        {
