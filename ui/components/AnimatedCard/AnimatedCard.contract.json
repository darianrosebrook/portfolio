{
  "name": "AnimatedCard",
  "layer": "primitive",
  "anatomy": [
    "root",
    "animatedCard",
    "hoverable",
    "cardImage",
    "cardTitle",
    "cardOverlay",
    "cardImageWrapper"
  ],
  "variants": {
    "as": [
      "article",
      "div",
      "li",
      "a"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"animated-card\"]"
    }
  },
  "a11y": {
    "role": "generic",
    "labeling": [],
    "keyboard": [],
    "apgPattern": null
  },
  "tokens": {},
  "props": {
    "designed": {
      "members": [
        {
          "name": "as",
          "type": "\"article\" | \"div\" | \"li\" | \"a\" | undefined",
          "description": "Element type to render",
          "required": false
        },
        {
          "name": "duration",
          "type": "number | undefined",
          "description": "Duration of entry animation in seconds",
          "required": false
        },
        {
          "name": "delay",
          "type": "number | undefined",
          "description": "Delay before animation starts in seconds",
          "required": false
        },
        {
          "name": "triggerOnScroll",
          "type": "boolean | undefined",
          "description": "Whether to trigger on scroll into view",
          "required": false
        },
        {
          "name": "scrollStart",
          "type": "string | undefined",
          "description": "ScrollTrigger start position",
          "required": false
        },
        {
          "name": "enableHover",
          "type": "boolean | undefined",
          "description": "Enable hover effects",
          "required": false
        },
        {
          "name": "href",
          "type": "string | undefined",
          "description": "Card href (if as=\"a\")",
          "required": false
        }
      ]
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "All transitions are disabled and the element appears at its final state immediately when prefers-reduced-motion is set.",
    "transitions": [
      {
        "name": "enter",
        "trigger": "visibility=offscreen\u2192visible",
        "phase": "enter",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.medium",
        "easing": "core.motion.easing.emphasizedOut"
      }
    ]
  },
  "description": "A card component that animates into view when it enters the viewport.",
  "a2ui": {
    "category": "animation",
    "usageHints": [
      "Wrap any card content inside AnimatedCard to apply the scroll-triggered entrance animation",
      "Respects prefers-reduced-motion \u2014 animation is disabled for users who prefer reduced motion",
      "Use delay to stagger multiple AnimatedCards in a grid"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "node-ref"
      ]
    }
  }
}
