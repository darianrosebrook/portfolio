{
  "name": "Tabs",
  "layer": "composer",
  "anatomy": [
    "root",
    "list",
    "indicator",
    "tab",
    "tabActive",
    "tabDisabled",
    "panel",
    "panelActive",
    "panelInactive"
  ],
  "variants": {
    "orientation": [
      "horizontal",
      "vertical"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus"
  ],
  "slots": {},
  "a11y": {
    "role": "tablist",
    "roles": [
      "tablist",
      "tab",
      "tabpanel"
    ],
    "labeling": [],
    "keyboard": [
      {
        "key": "Enter|Space",
        "when": "trigger",
        "then": "activate"
      },
      {
        "key": "ArrowLeft|ArrowRight",
        "when": "tablist",
        "then": "move focus"
      },
      {
        "key": "Enter|Space",
        "when": "tab",
        "then": "activate tab"
      }
    ],
    "apgPattern": null
  },
  "tokens": {
    "root": [
      "tabs.spacing.gap",
      "tabs.spacing.padding",
      "tabs.spacing.panelGap",
      "tabs.color.fg",
      "tabs.color.active-fg",
      "tabs.color.active-bg",
      "tabs.color.disabled-fg",
      "tabs.color.indicator",
      "tabs.color.focus",
      "tabs.color.hover.bg",
      "tabs.color.hover.fg",
      "tabs.shape.radius",
      "tabs.motion.indicator"
    ]
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  }
}
