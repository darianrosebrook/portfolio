{
  "name": "Tabs",
  "layer": "composer",
  "anatomy": [
    "root",
    "list",
    "indicator",
    "tab",
    "tabActive",
    "tabDisabled",
    "panel",
    "panelActive",
    "panelInactive"
  ],
  "variants": {
    "orientation": [
      "horizontal",
      "vertical"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"tabs\"]"
    },
    "list": {
      "required": true,
      "selector": "[data-slot=\"tabs-list\"]"
    },
    "indicator": {
      "required": false,
      "selector": "[data-slot=\"tabs-indicator\"]"
    },
    "tab": {
      "required": true,
      "selector": "[data-slot=\"tabs-tab\"]"
    },
    "panel": {
      "required": true,
      "selector": "[data-slot=\"tabs-panel\"]"
    }
  },
  "a11y": {
    "role": "tablist",
    "roles": [
      "tablist",
      "tab",
      "tabpanel"
    ],
    "labeling": [],
    "keyboard": [
      {
        "key": "Enter|Space",
        "when": "trigger",
        "then": "activate"
      },
      {
        "key": "ArrowLeft|ArrowRight",
        "when": "tablist",
        "then": "move focus"
      },
      {
        "key": "Enter|Space",
        "when": "tab",
        "then": "activate tab"
      }
    ],
    "apgPattern": null
  },
  "tokens": {
    "root": {
      "tabs.spacing.gap": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "gap",
        "layer": "core"
      },
      "tabs.spacing.padding": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "padding",
        "layer": "core"
      },
      "tabs.spacing.panelGap": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "gap",
        "layer": "core"
      },
      "tabs.color.fg": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "layer": "semantic"
      },
      "tabs.color.active-fg": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "layer": "semantic"
      },
      "tabs.color.active-bg": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "layer": "semantic"
      },
      "tabs.color.disabled-fg": {
        "resolvesTo": "semantic.color.foreground.disabled",
        "fallback": "#aeaeae",
        "layer": "semantic"
      },
      "tabs.color.indicator": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "tabs.color.focus": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "tabs.color.hover.bg": {
        "resolvesTo": "semantic.color.background.hover",
        "fallback": "#cecece",
        "layer": "semantic"
      },
      "tabs.color.hover.fg": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "layer": "semantic"
      },
      "tabs.shape.radius": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "tabs.motion.indicator": {
        "resolvesTo": "core.motion.duration.short",
        "fallback": "150ms",
        "layer": "core"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "defaultValue",
          "type": "string | undefined",
          "description": "defaultValue prop for Tabs.",
          "required": false
        },
        {
          "name": "value",
          "type": "string | undefined",
          "description": "value prop for Tabs.",
          "required": false
        },
        {
          "name": "activationMode",
          "type": "TabsActivationMode | undefined",
          "description": "activationMode prop for Tabs.",
          "required": false
        },
        {
          "name": "unmountInactive",
          "type": "boolean | undefined",
          "description": "unmountInactive prop for Tabs.",
          "required": false
        },
        {
          "name": "idBase",
          "type": "string | undefined",
          "description": "idBase prop for Tabs.",
          "required": false
        },
        {
          "name": "orientation",
          "type": "\"horizontal\" | \"vertical\" | undefined",
          "description": "orientation prop for Tabs.",
          "required": false
        },
        {
          "name": "loop",
          "type": "boolean | undefined",
          "description": "loop prop for Tabs.",
          "required": false
        },
        {
          "name": "title",
          "type": "string | undefined",
          "description": "title prop for Tabs.",
          "required": false
        }
      ]
    },
    "passthrough": {
      "extends": "div"
    }
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "Active indicator moves instantly without animation when prefers-reduced-motion is set.",
    "transitions": [
      {
        "name": "indicator",
        "trigger": "activeTab=changed",
        "phase": "enter",
        "properties": [
          "transform",
          "width"
        ],
        "duration": "tabs.motion.indicator",
        "easing": null
      }
    ]
  },
  "focus": {
    "strategy": "roving",
    "orientation": "horizontal",
    "initialFocus": "activeTab",
    "wrap": true,
    "description": "Arrow keys move focus between tabs; focus follows the active indicator. Tab panels are reached with Tab key."
  },
  "portal": {
    "enabled": false
  },
  "dismissal": {
    "triggers": []
  },
  "relationships": [
    {
      "from": "tab",
      "to": "panel",
      "attribute": "aria-controls",
      "description": "Each tab controls its associated tab panel."
    },
    {
      "from": "panel",
      "to": "tab",
      "attribute": "aria-labelledby",
      "description": "Each tab panel is labelled by its corresponding tab."
    }
  ],
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "channels": {
    "activeTab": {
      "description": "The value of the currently active tab.",
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onValueChange",
      "valueType": "string"
    }
  },
  "description": "Tabbed navigation for switching between related content panels within the same page context.",
  "a2ui": {
    "category": "navigation",
    "usageHints": [
      "Bind value and onValueChange for controlled tabs; use defaultValue for uncontrolled",
      "Use activationMode=\"manual\" when tab panels are expensive to render (focus without selecting)",
      "Each Tab must have a corresponding TabsContent with a matching value string",
      "Use orientation=\"vertical\" for sidebar-style tab lists"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "TabsList",
        "TabsTrigger",
        "TabsContent"
      ]
    }
  }
}
