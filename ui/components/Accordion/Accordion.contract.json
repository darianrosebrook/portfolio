{
  "name": "Accordion",
  "layer": "composer",
  "anatomy": [
    "root",
    "content",
    "item",
    "trigger",
    "header",
    "chevron",
    "contentInner"
  ],
  "variants": {
    "type": [
      "single",
      "multiple"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "disabled",
    "open",
    "closed"
  ],
  "slots": {
    "content": {
      "required": false,
      "selector": "[data-slot=\"accordion-content\"]"
    },
    "item": {
      "required": false,
      "selector": "[data-slot=\"accordion-item\"]"
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"accordion\"]"
    },
    "trigger": {
      "required": false,
      "selector": "[data-slot=\"accordion-trigger\"]"
    }
  },
  "a11y": {
    "role": "region",
    "labeling": [],
    "keyboard": [
      {
        "key": "Enter|Space",
        "when": "trigger",
        "then": "toggle item"
      }
    ],
    "apgPattern": null
  },
  "tokens": {
    "root": {
      "accordion.color.background.hover": {
        "resolvesTo": "semantic.interaction.background.hover",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "accordion.color.text": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "accordion.color.textHover": {
        "resolvesTo": "semantic.interaction.text.hover",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "accordion.color.textSecondary": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "accordion.color.icon": {
        "resolvesTo": "semantic.color.foreground.tertiary",
        "fallback": "#717171",
        "layer": "semantic"
      },
      "accordion.border.width": {
        "resolvesTo": "core.shape.border.width.hairline",
        "fallback": "1px",
        "property": "border-width",
        "layer": "core"
      },
      "accordion.border.color": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "property": "border-color",
        "layer": "semantic"
      },
      "accordion.border.radius": {
        "resolvesTo": "core.shape.radius.small",
        "fallback": "4px",
        "property": "border-radius",
        "layer": "core"
      },
      "accordion.spacing.gap": {
        "resolvesTo": "core.spacing.size.07",
        "fallback": "24px",
        "property": "gap",
        "layer": "core"
      },
      "accordion.spacing.paddingX": {
        "resolvesTo": "core.spacing.size.00",
        "fallback": "0px",
        "property": "padding",
        "layer": "core"
      },
      "accordion.spacing.paddingY": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "padding",
        "layer": "core"
      },
      "accordion.text.weight": {
        "resolvesTo": "semantic.typography.font.weight.medium",
        "fallback": "500",
        "property": "font-weight",
        "layer": "semantic"
      },
      "accordion.text.size": {
        "resolvesTo": "semantic.typography.body.02",
        "fallback": "16px",
        "property": "font-size",
        "layer": "semantic"
      },
      "accordion.text.lineHeight": {
        "resolvesTo": "semantic.typography.line.height.normal",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      },
      "accordion.text.sizeContent": {
        "resolvesTo": "semantic.typography.body.03",
        "fallback": "14px",
        "property": "font-size",
        "layer": "semantic"
      },
      "accordion.text.lineHeightContent": {
        "resolvesTo": "semantic.typography.line.height.loose",
        "fallback": "1.8",
        "property": "line-height",
        "layer": "semantic"
      },
      "accordion.icon.size": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "layer": "core"
      },
      "accordion.icon.offset": {
        "resolvesTo": "core.spacing.size.01",
        "fallback": "1px",
        "layer": "core"
      },
      "accordion.motion.duration": {
        "resolvesTo": "core.motion.duration.medium",
        "fallback": "250ms",
        "property": "transition-duration",
        "layer": "core"
      },
      "accordion.motion.easing": {
        "resolvesTo": "core.motion.easing.standard",
        "fallback": "cubic-bezier(0.4, 0, 0.2, 1)",
        "property": "transition-timing-function",
        "layer": "core"
      },
      "accordion.focus.width": {
        "resolvesTo": "core.shape.border.width.thick",
        "fallback": "2px",
        "layer": "core"
      },
      "accordion.focus.color": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "accordion.focus.offset": {
        "resolvesTo": "core.spacing.size.01",
        "fallback": "1px",
        "layer": "core"
      },
      "accordion.opacity.disabled": {
        "resolvesTo": "semantic.interaction.disabled.opacity",
        "fallback": "0.5",
        "property": "opacity",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "type",
          "type": "AccordionType | undefined",
          "description": "type prop for Accordion.",
          "required": false
        },
        {
          "name": "defaultValue",
          "type": "string | string[] | undefined",
          "description": "defaultValue prop for Accordion.",
          "required": false
        },
        {
          "name": "value",
          "type": "string | string[] | undefined",
          "description": "value prop for Accordion.",
          "required": false
        },
        {
          "name": "collapsible",
          "type": "boolean | undefined",
          "description": "collapsible prop for Accordion.",
          "required": false
        },
        {
          "name": "title",
          "type": "string | undefined",
          "description": "title prop for Accordion.",
          "required": false
        }
      ]
    },
    "passthrough": {
      "extends": "div"
    }
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "Duration set to 0; panels snap between collapsed and expanded states without height animation.",
    "transitions": [
      {
        "name": "expand",
        "trigger": "openness=collapsed\u2192expanded",
        "phase": "enter",
        "properties": [
          "height",
          "opacity"
        ],
        "duration": "accordion.motion.duration",
        "easing": "accordion.motion.easing"
      },
      {
        "name": "collapse",
        "trigger": "openness=expanded\u2192collapsed",
        "phase": "exit",
        "properties": [
          "height",
          "opacity"
        ],
        "duration": "accordion.motion.duration",
        "easing": "accordion.motion.easing"
      }
    ]
  },
  "focus": {
    "strategy": "manual",
    "orientation": "vertical",
    "initialFocus": "trigger",
    "wrap": true,
    "description": "Arrow keys navigate between accordion triggers; Space/Enter toggles the focused panel."
  },
  "portal": {
    "enabled": false
  },
  "dismissal": {
    "triggers": []
  },
  "relationships": [
    {
      "from": "trigger",
      "to": "panel",
      "attribute": "aria-controls",
      "description": "Each accordion trigger controls its associated panel region."
    },
    {
      "from": "panel",
      "to": "trigger",
      "attribute": "aria-labelledby",
      "description": "Each panel is labelled by its corresponding trigger heading."
    }
  ],
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": true
  },
  "channels": {
    "openness": {
      "description": "Which panel(s) are expanded. String in single mode, string[] in multiple mode.",
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onValueChange",
      "valueType": "string | string[]"
    }
  },
  "description": "Vertically stacked sections that expand/collapse to reveal content. Supports single or multi-panel open modes.",
  "a2ui": {
    "category": "navigation",
    "usageHints": [
      "Use type=\"single\" to allow only one panel open at a time; \"multiple\" allows several",
      "Set collapsible on single mode to allow the open panel to also be closed",
      "Bind value and onValueChange for controlled mode",
      "Avoid deeply nesting accordions \u2014 prefer flat structures for better readability"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "AccordionItem",
        "AccordionTrigger",
        "AccordionContent"
      ]
    }
  }
}
