{
  "name": "Blockquote",
  "layer": "primitive",
  "anatomy": [
    "root"
  ],
  "variants": {
    "variant": [
      "default",
      "bordered",
      "highlighted"
    ],
    "size": [
      "sm",
      "md",
      "lg"
    ]
  },
  "states": [
    "default"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"blockquote\"]"
    }
  },
  "a11y": {
    "role": "generic",
    "labeling": [],
    "keyboard": [],
    "apgPattern": null
  },
  "tokens": {
    "root": {
      "blockquote.color.foreground.primary": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "blockquote.color.background.default": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "blockquote.color.border.default": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      },
      "blockquote.color.border.accent": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      },
      "blockquote.typography.fontStyle": {
        "resolvesTo": "semantic.typography.font.style.italic",
        "fallback": "italic",
        "layer": "semantic"
      },
      "blockquote.typography.fontWeight": {
        "resolvesTo": "semantic.typography.font.weight.medium",
        "fallback": "500",
        "layer": "semantic"
      },
      "blockquote.typography.sm.fontSize": {
        "resolvesTo": "semantic.typography.body.03",
        "fallback": "14px",
        "layer": "semantic"
      },
      "blockquote.typography.sm.lineHeight": {
        "resolvesTo": "semantic.typography.line.height.body",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      },
      "blockquote.typography.md.fontSize": {
        "resolvesTo": "semantic.typography.body.02",
        "fallback": "16px",
        "layer": "semantic"
      },
      "blockquote.typography.md.lineHeight": {
        "resolvesTo": "semantic.typography.line.height.body",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      },
      "blockquote.typography.lg.fontSize": {
        "resolvesTo": "semantic.typography.body.01",
        "fallback": "18px",
        "layer": "semantic"
      },
      "blockquote.typography.lg.lineHeight": {
        "resolvesTo": "semantic.typography.line.height.body",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      },
      "blockquote.size.padding.default": {
        "resolvesTo": "core.spacing.size.05",
        "fallback": "12px",
        "property": "padding",
        "layer": "core"
      },
      "blockquote.size.radius.default": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "blockquote.size.border.thick": {
        "resolvesTo": "core.shape.border.width.thick",
        "fallback": "2px",
        "layer": "core"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "cite",
          "type": "string | undefined",
          "description": "Citation or source of the quote",
          "required": false
        },
        {
          "name": "variant",
          "type": "\"default\" | \"bordered\" | \"highlighted\" | undefined",
          "description": "Visual variant of the blockquote",
          "required": false
        },
        {
          "name": "defaultValue",
          "type": "string | number | readonly string[] | undefined",
          "description": "defaultValue prop for Blockquote.",
          "required": false
        },
        {
          "name": "title",
          "type": "string | undefined",
          "description": "title prop for Blockquote.",
          "required": false
        }
      ]
    },
    "passthrough": {
      "extends": "blockquote"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "description": "Styled blockquote for displaying cited passages or testimonials.",
  "a2ui": {
    "category": "content",
    "usageHints": [
      "Set the cite prop to the URL of the source document (not the visible citation text)",
      "Pair with a figcaption sibling for the attribution text"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "string",
        "node-ref"
      ]
    }
  }
}
