{
  "name": "Field",
  "layer": "composer",
  "anatomy": [
    "root",
    "error",
    "help",
    "label",
    "header",
    "control",
    "meta",
    "validatingIndicator"
  ],
  "variants": {
    "status": [
      "idle",
      "validating",
      "valid",
      "invalid"
    ]
  },
  "states": [
    "default",
    "focus",
    "disabled"
  ],
  "slots": {
    "error": {
      "required": false
    },
    "help": {
      "required": false
    },
    "label": {
      "required": false
    }
  },
  "a11y": {
    "role": "alert",
    "roles": [
      "alert",
      "group",
      "radiogroup"
    ],
    "labeling": [
      "aria-labelledby",
      "aria-describedby",
      "aria-errormessage"
    ],
    "keyboard": [],
    "apgPattern": "alert"
  },
  "tokens": {
    "root": {
      "field.gap.y": {
        "resolvesTo": "semantic.spacing.density.compact.sm",
        "fallback": "8px",
        "property": "gap",
        "layer": "semantic"
      },
      "field.gap.meta": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "property": "gap",
        "layer": "core"
      },
      "field.label.fontSize": {
        "resolvesTo": "semantic.typography.body.small.font.size",
        "fallback": "14px",
        "layer": "semantic"
      },
      "field.label.color": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "layer": "semantic"
      },
      "field.radius": {
        "resolvesTo": "semantic.shape.control.radius.default",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "semantic"
      },
      "field.pad.x": {
        "resolvesTo": "semantic.spacing.density.compact.md",
        "fallback": "12px",
        "layer": "semantic"
      },
      "field.pad.y": {
        "resolvesTo": "semantic.spacing.density.compact.sm",
        "fallback": "8px",
        "layer": "semantic"
      },
      "field.color.bg": {
        "resolvesTo": "semantic.color.background.elevated",
        "fallback": "#ffffff",
        "layer": "semantic"
      },
      "field.color.fg": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "layer": "semantic"
      },
      "field.color.border": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "property": "border-color",
        "layer": "semantic"
      },
      "field.color.borderBold": {
        "resolvesTo": "semantic.color.border.bold",
        "fallback": "#8f8f8f",
        "property": "border-color",
        "layer": "semantic"
      },
      "field.color.focus-border": {
        "resolvesTo": "semantic.color.border.focus",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "field.color.focus-text": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "field.color.invalid-border": {
        "resolvesTo": "semantic.color.border.danger",
        "fallback": "#ae0001",
        "layer": "semantic"
      },
      "field.color.invalid-text": {
        "resolvesTo": "semantic.color.foreground.danger",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "field.color.valid-border": {
        "resolvesTo": "semantic.color.feedback.border.success",
        "fallback": "#336006",
        "layer": "semantic"
      },
      "field.spacing.indicator": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "layer": "core"
      }
    },
    "label": {
      "field.label.fontSize": {
        "resolvesTo": "semantic.typography.body.small.font.size",
        "fallback": "14px",
        "layer": "semantic"
      },
      "field.label.color": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "layer": "semantic"
      }
    }
  },
  "ssr": {
    "hydrateOn": "none"
  },
  "rtl": {
    "flipIcon": false
  }
}
