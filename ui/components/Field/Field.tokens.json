{
  "prefix": "field",
  "tokens": {
    "gap": {
      "y": "{semantic.spacing.density.compact.sm}",
      "meta": "{core.spacing.size.03}"
    },
    "label": {
      "fontSize": "{semantic.typography.body.small.fontSize}",
      "color": "{semantic.color.foreground.secondary}"
    },
    "radius": "{semantic.shape.control.radius.default}",
    "pad": {
      "x": "{semantic.spacing.density.compact.md}",
      "y": "{semantic.spacing.density.compact.sm}"
    },
    "color": {
      "bg": "{semantic.color.background.elevated}",
      "fg": "{semantic.color.foreground.primary}",
      "border": "{semantic.color.border.subtle}",
      "borderBold": "{semantic.color.border.bold}",
      "focus-border": "{semantic.color.border.focus}",
      "focus-text": "{semantic.color.border.accent}",
      "invalid-border": "{semantic.color.border.danger}",
      "invalid-text": "{semantic.color.foreground.danger}",
      "valid-border": "{semantic.color.feedback.border.success}"
    },
    "spacing": {
      "indicator": "{core.spacing.size.03}"
    }
  }
}
