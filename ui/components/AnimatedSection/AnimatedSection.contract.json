{
  "name": "AnimatedSection",
  "layer": "primitive",
  "anatomy": [
    "root",
    "animatedSection",
    "animatedChild"
  ],
  "variants": {
    "as": [
      "section",
      "div",
      "article",
      "main",
      "aside",
      "header",
      "footer"
    ],
    "variant": [
      "fade-up",
      "fade-in",
      "slide-in",
      "stagger-children"
    ]
  },
  "states": [
    "default"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"animated-section\"]"
    }
  },
  "a11y": {
    "role": "generic",
    "labeling": [],
    "keyboard": [],
    "apgPattern": null
  },
  "tokens": {},
  "props": {
    "designed": {
      "members": [
        {
          "name": "as",
          "type": "\"section\" | \"div\" | \"article\" | \"main\" | \"aside\" | \"header\" | \"footer\" | undefined",
          "description": "Element type to render",
          "required": false
        },
        {
          "name": "variant",
          "type": "\"fade-up\" | \"fade-in\" | \"slide-in\" | \"stagger-children\" | undefined",
          "description": "Animation variant",
          "required": false
        },
        {
          "name": "duration",
          "type": "number | undefined",
          "description": "Duration of animation in seconds",
          "required": false
        },
        {
          "name": "stagger",
          "type": "number | undefined",
          "description": "Stagger delay between children in seconds (for stagger-children variant)",
          "required": false
        },
        {
          "name": "delay",
          "type": "number | undefined",
          "description": "Delay before animation starts in seconds",
          "required": false
        },
        {
          "name": "triggerOnScroll",
          "type": "boolean | undefined",
          "description": "Whether to trigger on scroll into view",
          "required": false
        },
        {
          "name": "scrollStart",
          "type": "string | undefined",
          "description": "ScrollTrigger start position",
          "required": false
        }
      ]
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "All transitions are disabled and the section appears at its final state immediately when prefers-reduced-motion is set.",
    "transitions": [
      {
        "name": "enter",
        "trigger": "visibility=offscreen\u2192visible",
        "phase": "enter",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.medium",
        "easing": "core.motion.easing.emphasizedOut"
      }
    ]
  },
  "description": "A page section that fades and slides into view when it enters the viewport.",
  "a2ui": {
    "category": "animation",
    "usageHints": [
      "Wrap page sections in AnimatedSection for a scroll-reveal effect",
      "Respects prefers-reduced-motion",
      "Combine with AnimatedCard children for layered entrance effects"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "node-ref"
      ]
    }
  }
}
