{
  "name": "Toast",
  "layer": "composer",
  "anatomy": [
    "root",
    "action",
    "close",
    "description",
    "title",
    "viewport",
    "item",
    "row"
  ],
  "variants": {
    "politeness": [
      "polite",
      "assertive"
    ],
    "variant": [
      "info",
      "success",
      "warning",
      "error"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "entering",
    "visible",
    "leaving"
  ],
  "slots": {
    "action": {
      "required": false
    },
    "close": {
      "required": false
    },
    "description": {
      "required": false
    },
    "title": {
      "required": false
    }
  },
  "a11y": {
    "role": "alert",
    "roles": [
      "alert",
      "status"
    ],
    "labeling": [
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "Enter|Space",
        "when": "trigger",
        "then": "activate"
      }
    ],
    "apgPattern": "alert"
  },
  "tokens": {
    "root": [
      "toast.surface.bg",
      "toast.surface.border",
      "toast.surface.radius",
      "toast.surface.shadow",
      "toast.color.info",
      "toast.color.success",
      "toast.color.warning",
      "toast.color.error",
      "toast.accent.info",
      "toast.accent.success",
      "toast.accent.warning",
      "toast.accent.error",
      "toast.spacing.padding",
      "toast.spacing.gap",
      "toast.spacing.stackGap",
      "toast.size.maxWidth.value",
      "toast.size.maxWidth.unit",
      "toast.motion.enter",
      "toast.motion.leave"
    ]
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  }
}
