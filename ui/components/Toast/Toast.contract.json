{
  "name": "Toast",
  "layer": "composer",
  "anatomy": [
    "root",
    "action",
    "close",
    "description",
    "title",
    "viewport",
    "item",
    "row"
  ],
  "variants": {
    "politeness": [
      "polite",
      "assertive"
    ],
    "variant": [
      "info",
      "success",
      "warning",
      "error"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "entering",
    "visible",
    "leaving"
  ],
  "slots": {
    "viewport": {
      "required": true,
      "selector": "[data-slot=\"toast-viewport\"]"
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"toast\"]"
    },
    "title": {
      "required": false,
      "selector": "[data-slot=\"toast-title\"]"
    },
    "description": {
      "required": false,
      "selector": "[data-slot=\"toast-description\"]"
    },
    "row": {
      "required": false,
      "selector": "[data-slot=\"toast-row\"]"
    },
    "action": {
      "required": false,
      "selector": "[data-slot=\"toast-action\"]"
    },
    "close": {
      "required": false,
      "selector": "[data-slot=\"toast-close\"]"
    }
  },
  "a11y": {
    "role": "alert",
    "roles": [
      "alert",
      "status"
    ],
    "labeling": [
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "Enter|Space",
        "when": "trigger",
        "then": "activate"
      }
    ],
    "apgPattern": "alert"
  },
  "tokens": {
    "root": {
      "toast.surface.bg": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "layer": "semantic"
      },
      "toast.surface.border": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "layer": "semantic"
      },
      "toast.surface.radius": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "toast.surface.shadow": {
        "resolvesTo": "semantic.elevation.surface.raised",
        "fallback": "[object Object]",
        "property": "box-shadow",
        "layer": "semantic"
      },
      "toast.color.info": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "layer": "semantic"
      },
      "toast.color.success": {
        "resolvesTo": "semantic.color.foreground.success",
        "fallback": "#487e1e",
        "layer": "semantic"
      },
      "toast.color.warning": {
        "resolvesTo": "semantic.color.foreground.warning",
        "fallback": "#ac5c00",
        "layer": "semantic"
      },
      "toast.color.error": {
        "resolvesTo": "semantic.color.foreground.danger",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "toast.accent.info": {
        "resolvesTo": "semantic.color.status.info",
        "fallback": "#0a65fe",
        "layer": "semantic"
      },
      "toast.accent.success": {
        "resolvesTo": "semantic.color.status.success",
        "fallback": "#487e1e",
        "layer": "semantic"
      },
      "toast.accent.warning": {
        "resolvesTo": "semantic.color.status.warning",
        "fallback": "#ac5c00",
        "layer": "semantic"
      },
      "toast.accent.error": {
        "resolvesTo": "semantic.color.status.danger",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "toast.spacing.padding": {
        "resolvesTo": "core.spacing.size.05",
        "fallback": "12px",
        "property": "padding",
        "layer": "core"
      },
      "toast.spacing.gap": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "gap",
        "layer": "core"
      },
      "toast.spacing.stackGap": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "gap",
        "layer": "core"
      },
      "toast.size.maxWidth": {
        "literal": "400px"
      },
      "toast.motion.enter": {
        "resolvesTo": "core.motion.duration.short",
        "fallback": "150ms",
        "layer": "core"
      },
      "toast.motion.leave": {
        "resolvesTo": "core.motion.duration.short",
        "fallback": "150ms",
        "layer": "core"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "politeness",
          "type": "\"polite\" | \"assertive\" | undefined",
          "description": "politeness prop for Toast.",
          "required": false
        },
        {
          "name": "defaultValue",
          "type": "string | number | readonly string[] | undefined",
          "description": "defaultValue prop for Toast.",
          "required": false
        },
        {
          "name": "title",
          "type": "string | undefined",
          "description": "title prop for Toast.",
          "required": false
        }
      ]
    },
    "passthrough": {
      "extends": "div"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "description": "Transient notification message appearing briefly at the edge of the viewport.",
  "a2ui": {
    "category": "overlay",
    "usageHints": [
      "Trigger toasts via the useToast hook or ToastProvider API \u2014 do not render Toast directly",
      "Use variant to set the visual style (default, success, warning, error)",
      "Toasts are live regions \u2014 screen readers announce them without requiring focus",
      "Keep toast messages brief; use an action button only for critical reversible operations"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "ToastTitle",
        "ToastDescription",
        "ToastAction",
        "ToastClose"
      ]
    }
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "Duration set to 0 so enter/exit collapses to immediate show/hide.",
    "transitions": [
      {
        "name": "open",
        "trigger": "openness=hidden\u2192visible",
        "phase": "enter",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasizedDecelerate"
      },
      {
        "name": "close",
        "trigger": "openness=visible\u2192hidden",
        "phase": "exit",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasizedAccelerate"
      }
    ]
  },
  "focus": {
    "strategy": "none",
    "description": "ToastViewport is an ARIA live region. Toasts appear without moving keyboard focus."
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "positioning": "fixed",
    "layering": "popover"
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape",
        "defaultEnabled": true,
        "description": "Dismisses the focused toast."
      },
      {
        "event": "userDismiss",
        "defaultEnabled": true,
        "description": "Clicking the close button on a toast."
      }
    ]
  },
  "relationships": [
    {
      "from": "toast",
      "to": "title",
      "attribute": "aria-labelledby",
      "description": "Each toast has an implicit aria-live region; the title provides accessible labeling."
    }
  ],
  "channels": {
    "openness": {
      "description": "Per-toast visibility managed by ToastProvider.",
      "value": "open",
      "defaultValue": "open",
      "onChange": "onOpenChange",
      "valueType": "boolean"
    }
  }
}
