{
  "name": "Truncate",
  "layer": "primitive",
  "anatomy": [
    "root",
    "content",
    "expandable",
    "toggle"
  ],
  "variants": {},
  "states": [
    "default",
    "hover",
    "focus",
    "expanded"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"truncate\"]"
    },
    "content": {
      "required": true,
      "selector": "[data-slot=\"truncate-content\"]"
    },
    "toggle": {
      "required": false,
      "selector": "[data-slot=\"truncate-toggle\"]"
    }
  },
  "a11y": {
    "role": "generic",
    "labeling": [],
    "keyboard": [
      {
        "key": "Enter|Space",
        "when": "trigger",
        "then": "activate"
      }
    ],
    "apgPattern": null
  },
  "tokens": {
    "root": {
      "truncate.color.foreground.link": {
        "resolvesTo": "semantic.color.foreground.link",
        "fallback": "#d9292b",
        "property": "color",
        "layer": "semantic"
      },
      "truncate.color.foreground.linkHover": {
        "resolvesTo": "semantic.color.foreground.link.hover",
        "fallback": "#ae0001",
        "property": "color",
        "layer": "semantic"
      },
      "truncate.color.background.primary": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "property": "background-color",
        "layer": "semantic"
      },
      "truncate.typography.fontWeight": {
        "resolvesTo": "semantic.typography.font.weight.medium",
        "fallback": "500",
        "layer": "semantic"
      },
      "truncate.spacing.toggle": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "layer": "core"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "as",
          "type": "keyof React.JSX.IntrinsicElements | undefined",
          "description": "Element type to render",
          "required": false
        },
        {
          "name": "lines",
          "type": "number | undefined",
          "description": "Number of lines to show before truncating",
          "required": false
        },
        {
          "name": "expandable",
          "type": "boolean | undefined",
          "description": "Whether to show expand/collapse functionality",
          "required": false
        },
        {
          "name": "expandText",
          "type": "string | undefined",
          "description": "Custom expand text",
          "required": false
        },
        {
          "name": "collapseText",
          "type": "string | undefined",
          "description": "Custom collapse text",
          "required": false
        },
        {
          "name": "defaultValue",
          "type": "string | number | readonly string[] | undefined",
          "description": "defaultValue prop for Truncate.",
          "required": false
        },
        {
          "name": "title",
          "type": "string | undefined",
          "description": "title prop for Truncate.",
          "required": false
        }
      ]
    },
    "passthrough": {
      "extends": "div"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "channels": {
    "expanded": {
      "description": "Whether the truncated content is fully visible.",
      "value": "expanded",
      "onChange": "onExpandedChange",
      "valueType": "boolean"
    }
  },
  "description": "Clamps multi-line text to a fixed number of lines with an expand/collapse toggle.",
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Set lines to control the maximum number of visible lines before truncation",
      "Set expandable=false to hard-truncate without a toggle button",
      "Use expandText and collapseText to customize the toggle button labels",
      "Bind expanded and onExpandedChange for controlled mode"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "string",
        "node-ref"
      ]
    }
  }
}
