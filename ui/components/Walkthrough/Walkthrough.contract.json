{
  "name": "Walkthrough",
  "layer": "composer",
  "anatomy": [
    "root",
    "content",
    "title",
    "description",
    "controls",
    "skip",
    "prev",
    "next",
    "dots",
    "dot",
    "dotActive",
    "counter"
  ],
  "variants": {
    "placement": [
      "top",
      "bottom",
      "left",
      "right",
      "auto"
    ]
  },
  "states": [
    "default",
    "hover",
    "disabled"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"walkthrough\"]"
    },
    "title": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-title\"]"
    },
    "description": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-description\"]"
    },
    "controls": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-controls\"]"
    },
    "skip": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-skip\"]"
    },
    "prev": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-prev\"]"
    },
    "next": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-next\"]"
    },
    "progress": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-progress\"]"
    },
    "dot": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-dot\"]"
    },
    "counter": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-counter\"]"
    }
  },
  "a11y": {
    "role": "status",
    "labeling": [
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "Enter|Space",
        "when": "trigger",
        "then": "activate"
      },
      {
        "key": "Escape",
        "when": "open",
        "then": "close"
      },
      {
        "key": "ArrowLeft",
        "when": "active",
        "then": "prev"
      },
      {
        "key": "ArrowRight",
        "when": "active",
        "then": "next"
      }
    ],
    "apgPattern": "status"
  },
  "tokens": {
    "root": {
      "walkthrough.surface.bg": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "layer": "semantic"
      },
      "walkthrough.surface.border": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "layer": "semantic"
      },
      "walkthrough.surface.radius": {
        "resolvesTo": "core.shape.radius.04",
        "fallback": "16px",
        "property": "border-radius",
        "layer": "core"
      },
      "walkthrough.surface.shadow": {
        "resolvesTo": "semantic.elevation.surface.floating",
        "fallback": "[object Object]",
        "property": "box-shadow",
        "layer": "semantic"
      },
      "walkthrough.surface.padding": {
        "resolvesTo": "core.spacing.size.08",
        "fallback": "32px",
        "property": "padding",
        "layer": "core"
      },
      "walkthrough.title.fontSize": {
        "resolvesTo": "semantic.typography.heading.03",
        "fallback": "20px",
        "layer": "semantic"
      },
      "walkthrough.title.fontWeight": {
        "resolvesTo": "semantic.typography.font.weight.bold",
        "fallback": "700",
        "layer": "semantic"
      },
      "walkthrough.title.color": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "layer": "semantic"
      },
      "walkthrough.description.fontSize": {
        "resolvesTo": "semantic.typography.body.02",
        "fallback": "16px",
        "layer": "semantic"
      },
      "walkthrough.description.color": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "layer": "semantic"
      },
      "walkthrough.description.marginTop": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "layer": "core"
      },
      "walkthrough.controls.gap": {
        "resolvesTo": "core.spacing.size.05",
        "fallback": "12px",
        "property": "gap",
        "layer": "core"
      },
      "walkthrough.controls.marginTop": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "layer": "core"
      },
      "walkthrough.dots.size": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "layer": "core"
      },
      "walkthrough.dots.gap": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "property": "gap",
        "layer": "core"
      },
      "walkthrough.dots.active": {
        "resolvesTo": "semantic.color.action.background.primary.default",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "walkthrough.dots.idle": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "layer": "semantic"
      },
      "walkthrough.button.primary.bg": {
        "resolvesTo": "semantic.color.action.background.primary.default",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "walkthrough.button.primary.color": {
        "resolvesTo": "semantic.color.action.foreground.primary.default",
        "fallback": "#ffffff",
        "layer": "semantic"
      },
      "walkthrough.button.primary.radius": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "walkthrough.button.primary.paddingY": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "padding",
        "layer": "core"
      },
      "walkthrough.button.primary.paddingX": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "padding",
        "layer": "core"
      },
      "walkthrough.button.secondary.bg": {
        "resolvesTo": "core.color.mode.transparent",
        "fallback": "#00000000",
        "layer": "core"
      },
      "walkthrough.button.secondary.color": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "layer": "semantic"
      },
      "walkthrough.button.secondary.border": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "layer": "semantic"
      },
      "walkthrough.button.secondary.radius": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "walkthrough.button.secondary.paddingY": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "padding",
        "layer": "core"
      },
      "walkthrough.button.secondary.paddingX": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "padding",
        "layer": "core"
      }
    },
    "title": {
      "walkthrough.title.fontSize": {
        "resolvesTo": "semantic.typography.heading.03",
        "fallback": "20px",
        "layer": "semantic"
      },
      "walkthrough.title.fontWeight": {
        "resolvesTo": "semantic.typography.font.weight.bold",
        "fallback": "700",
        "layer": "semantic"
      },
      "walkthrough.title.color": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "layer": "semantic"
      }
    },
    "description": {
      "walkthrough.description.fontSize": {
        "resolvesTo": "semantic.typography.body.02",
        "fallback": "16px",
        "layer": "semantic"
      },
      "walkthrough.description.color": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "layer": "semantic"
      },
      "walkthrough.description.marginTop": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "layer": "core"
      }
    },
    "controls": {
      "walkthrough.controls.gap": {
        "resolvesTo": "core.spacing.size.05",
        "fallback": "12px",
        "property": "gap",
        "layer": "core"
      },
      "walkthrough.controls.marginTop": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "layer": "core"
      }
    },
    "dots": {
      "walkthrough.dots.size": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "layer": "core"
      },
      "walkthrough.dots.gap": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "property": "gap",
        "layer": "core"
      },
      "walkthrough.dots.active": {
        "resolvesTo": "semantic.color.action.background.primary.default",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "walkthrough.dots.idle": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "hook": {
      "members": [
        {
          "name": "stepsProp",
          "type": "WalkthroughStepSpec[] | undefined",
          "description": "",
          "required": false
        },
        {
          "name": "defaultIndex",
          "type": "number | undefined",
          "description": "",
          "required": false
        },
        {
          "name": "index",
          "type": "number | undefined",
          "description": "",
          "required": false
        },
        {
          "name": "storageKey",
          "type": "string | undefined",
          "description": "",
          "required": false
        },
        {
          "name": "autoStart",
          "type": "boolean | undefined",
          "description": "",
          "required": false
        },
        {
          "name": "allowConcurrent",
          "type": "boolean | undefined",
          "description": "",
          "required": false
        },
        {
          "name": "closeOnOutsideClick",
          "type": "boolean | undefined",
          "description": "",
          "required": false
        }
      ]
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "description": "Step-by-step guided tour overlay anchored to page elements. Manages step progression and keyboard navigation.",
  "a2ui": {
    "category": "overlay",
    "usageHints": [
      "Define each step as a WalkthroughStep with an anchor ref and content",
      "WalkthroughAnchor wraps the element each step points to",
      "Use WalkthroughControls and WalkthroughProgress for navigation UI",
      "Keyboard: ArrowRight/ArrowLeft navigate steps; Escape closes the tour",
      "The walkthrough is non-blocking — it does not trap focus to the panel"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "WalkthroughStep",
        "WalkthroughAnchor"
      ]
    }
  },
  "motion": {
    "reducedMotion": "respect",
    "transitions": [
      {
        "name": "open",
        "trigger": "openness=hidden→visible",
        "phase": "enter",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasizedDecelerate"
      },
      {
        "name": "close",
        "trigger": "openness=visible→hidden",
        "phase": "exit",
        "properties": [
          "opacity"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasizedAccelerate"
      }
    ]
  },
  "focus": {
    "strategy": "none",
    "description": "Walkthrough panels are non-blocking. Focus remains on the anchored element while the panel is visible."
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "positioning": "anchored",
    "layering": "popover",
    "collision": "flip-shift"
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape",
        "defaultEnabled": true
      },
      {
        "event": "outsideClick",
        "defaultEnabled": false,
        "description": "Disabled by default to avoid accidental tour exit."
      }
    ]
  },
  "relationships": [
    {
      "from": "panel",
      "to": "title",
      "attribute": "aria-labelledby"
    },
    {
      "from": "panel",
      "to": "description",
      "attribute": "aria-describedby"
    }
  ],
  "channels": {
    "step": {
      "description": "Active step index.",
      "value": "index",
      "defaultValue": "defaultIndex",
      "onChange": "onStepChange",
      "valueType": "number"
    }
  }
}
