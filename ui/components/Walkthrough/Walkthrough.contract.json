{
  "name": "Walkthrough",
  "layer": "composer",
  "anatomy": [
    "root",
    "content",
    "title",
    "description",
    "controls",
    "skip",
    "prev",
    "next",
    "dots",
    "dot",
    "dotActive",
    "counter"
  ],
  "variants": {
    "placement": [
      "top",
      "bottom",
      "left",
      "right",
      "auto"
    ]
  },
  "states": [
    "default",
    "hover",
    "disabled"
  ],
  "slots": {},
  "a11y": {
    "role": "status",
    "labeling": [
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "Enter|Space",
        "when": "trigger",
        "then": "activate"
      },
      {
        "key": "Escape",
        "when": "open",
        "then": "close"
      },
      {
        "key": "ArrowLeft",
        "when": "active",
        "then": "prev"
      },
      {
        "key": "ArrowRight",
        "when": "active",
        "then": "next"
      }
    ],
    "apgPattern": "status"
  },
  "tokens": {
    "root": {
      "walkthrough.surface.bg": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "layer": "semantic"
      },
      "walkthrough.surface.border": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "layer": "semantic"
      },
      "walkthrough.surface.radius": {
        "resolvesTo": "core.shape.radius.04",
        "fallback": "16px",
        "property": "border-radius",
        "layer": "core"
      },
      "walkthrough.surface.shadow": {
        "resolvesTo": "semantic.elevation.surface.floating",
        "fallback": "[object Object]",
        "property": "box-shadow",
        "layer": "semantic"
      },
      "walkthrough.surface.padding": {
        "resolvesTo": "core.spacing.size.08",
