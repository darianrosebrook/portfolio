    "caption": {
      "required": false,
      "selector": "[data-slot=\"table-caption\"]"
    },
    "cell": {
      "required": false,
      "selector": "[data-slot=\"table-cell\"]"
    },
    "container": {
      "required": false,
      "selector": "[data-slot=\"table-container\"]"
    },
    "element": {
      "required": false
    },
    "footer": {
      "required": false,
      "selector": "[data-slot=\"table-footer\"]"
    },
    "head": {
      "required": false,
      "selector": "[data-slot=\"table-head\"]"
    },
    "header": {
      "required": false,
      "selector": "[data-slot=\"table-header\"]"
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"table\"]"
    },
    "row": {
      "required": false,
      "selector": "[data-slot=\"table-row\"]"
    }
  },
  "a11y": {
