      "table.spacing.sortGap",
      "table.spacing.checkboxOffset",
      "table.size.cellHeight",
      "table.size.checkboxColumn",
      "table.size.radius",
      "table.text.size",
      "table.text.lineHeight",
      "table.text.sizeCaption",
      "table.text.sizeSort",
      "table.text.weightHead",
      "table.text.weightFooter",
      "table.motion.duration",
      "table.motion.easing",
      "table.focus.width",
      "table.focus.color",
      "table.focus.offset",
      "table.elevation.raised"
