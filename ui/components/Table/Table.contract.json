{
  "name": "Table",
  "layer": "compound",
  "anatomy": [
    "root",
    "body",
    "caption",
    "cell",
    "container",
    "element",
    "footer",
    "head",
    "header",
    "row",
    "responsive",
    "interactive",
    "sortable",
    "headContent",
    "sortIcon",
    "truncate",
    "data"
  ],
  "variants": {},
