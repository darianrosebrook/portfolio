  "props": {
    "designed": {
      "members": [
        {
          "name": "postId",
          "type": "string",
          "description": "postId prop for Postcard.",
          "required": true
        },
        {
          "name": "author",
          "type": "{ name: string; handle: string; avatar: string; }",
          "description": "author prop for Postcard.",
          "required": true
        },
        {
          "name": "timestamp",
          "type": "string",
          "description": "timestamp prop for Postcard.",
          "required": true
        },
        {
          "name": "embed",
          "type": "{ type: \"image\" | \"video\" | \"audio\"; url: string; aspectRatio: { width: number; height: number; }; } | undefined",
          "description": "embed prop for Postcard.",
          "required": false
        },
        {
          "name": "stats",
          "type": "{ likes: number; replies: number; reposts: number; }",
          "description": "stats prop for Postcard.",
          "required": true
        }
      ]
    },
