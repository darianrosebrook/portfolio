{
  "name": "Postcard",
  "layer": "composer",
  "anatomy": [
    "root",
    "post",
    "header",
    "userInfo",
    "displayName",
    "handle",
    "timestamp",
    "content",
    "footer",
    "stats",
    "stat"
  ],
  "variants": {
    "type": [
      "image",
      "video",
      "audio"
    ]
  },
  "states": [
    "default",
    "hover"
  ],
  "slots": {},
  "a11y": {
    "role": "region",
    "labeling": [],
    "keyboard": [
      {
        "key": "Enter|Space",
        "when": "trigger",
        "then": "activate"
      }
    ],
    "apgPattern": null
  },
  "tokens": {
    "root": [
      "postcard.color.background.default",
      "postcard.color.background.hover",
      "postcard.color.background.active",
      "postcard.color.border.default",
      "postcard.color.border.accent",
      "postcard.color.border.hover",
      "postcard.color.foreground.primary",
      "postcard.color.foreground.secondary",
      "postcard.color.foreground.muted",
      "postcard.size.padding.default",
      "postcard.size.radius.default",
      "postcard.size.radius.medium",
      "postcard.size.radius.full",
      "postcard.size.margin.bottom",
      "postcard.size.gap.default",
      "postcard.size.gap.small",
      "postcard.size.gap.large",
      "postcard.size.border.default",
      "postcard.typography.displayName.fontSize",
      "postcard.typography.displayName.fontWeight",
      "postcard.typography.handle.fontSize",
      "postcard.typography.content.fontSize",
      "postcard.typography.content.lineHeight",
      "postcard.typography.footer.fontSize"
    ],
    "displayName": [
      "postcard.typography.displayName.fontSize",
      "postcard.typography.displayName.fontWeight"
    ],
    "handle": {
      "postcard.typography.handle.fontSize": {
        "resolvesTo": "semantic.typography.body.03",
        "fallback": "14px",
        "layer": "semantic"
      }
    },
    "content": {
      "postcard.typography.content.fontSize": {
        "resolvesTo": "semantic.typography.body.02",
        "fallback": "16px",
        "layer": "semantic"
      },
      "postcard.typography.content.lineHeight": {
        "resolvesTo": "semantic.typography.line.height.body",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      }
    },
    "footer": {
      "postcard.typography.footer.fontSize": {
        "resolvesTo": "semantic.typography.body.03",
        "fallback": "14px",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "styled": {
      "members": [
        {
          "name": "postId",
          "type": "string",
          "description": "",
          "required": true
        },
        {
          "name": "author",
          "type": "{ name: string; handle: string; avatar: string; }",
          "description": "",
          "required": true
        },
        {
          "name": "timestamp",
          "type": "string",
          "description": "",
          "required": true
        },
        {
          "name": "content",
          "type": "string",
          "description": "",
          "required": true
        },
        {
          "name": "embed",
          "type": "{ type: \"image\" | \"video\" | \"audio\"; url: string; aspectRatio: { width: number; height: number; }; } | undefined",
          "description": "",
          "required": false
        },
        {
          "name": "stats",
          "type": "{ likes: number; replies: number; reposts: number; }",
          "description": "",
          "required": true
        }
      ]
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  }
}
