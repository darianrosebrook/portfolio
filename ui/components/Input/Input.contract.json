{
  "name": "Input",
  "layer": "primitive",
  "anatomy": [
    "root"
  ],
  "variants": {},
  "states": [
    "default",
    "hover",
    "focus",
    "disabled",
    "invalid"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"input\"]"
    }
  },
  "a11y": {
    "role": "generic",
    "labeling": [],
    "keyboard": [],
    "apgPattern": null
  },
  "tokens": {
    "root": {
      "input.color.bg.default": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "layer": "semantic"
      },
      "input.color.text.default": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "input.color.border.default": {
        "resolvesTo": "semantic.color.border.default",
        "fallback": "#aeaeae",
        "property": "border-color",
        "layer": "semantic"
      },
      "input.color.focus.default": {
        "resolvesTo": "semantic.color.border.focus",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "input.color.invalid.default": {
        "resolvesTo": "semantic.color.border.danger",
        "fallback": "#ae0001",
        "layer": "semantic"
      },
      "input.size.height.default": {
        "resolvesTo": "semantic.control.size.lg.height",
        "fallback": "48px",
        "property": "min-height",
        "layer": "semantic"
      },
      "input.size.radius.default": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "input.space.inline.default": {
        "resolvesTo": "core.spacing.size.05",
        "fallback": "12px",
        "layer": "core"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        { "name": "invalid", "type": "boolean | undefined", "description": "Marks the input as invalid: applies error styling and sets aria-invalid automatically.", "required": false }
      ]
    },
    "passthrough": {
      "extends": "input"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "channels": {
    "value": {
      "description": "The current text value of the input.",
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onChange",
      "valueType": "string"
    }
  },
  "form": {
    "participates": true,
    "inputType": "text",
    "name": {
      "prop": "name"
    },
    "required": {
      "prop": "required",
      "constraintValidation": true
    },
    "serialization": {
      "valueType": "string",
      "valueSource": "channel:value",
      "omitWhen": "never"
    },
    "validity": {
      "model": "hybrid",
      "invalidProp": "invalid",
      "ariaAttributes": [
        "aria-invalid",
        "aria-required",
        "aria-describedby"
      ]
    },
    "labeling": {
      "strategy": "associated-label",
      "required": true,
      "via": [
        "aria-labelledby",
        "aria-label"
      ]
    }
  },
  "description": "Native text input with portfolio-specific styling. Use inside TextField for label and error support.",
  "a2ui": {
    "category": "form-field",
    "usageHints": [
      "Prefer TextField over Input when you need a label, description, or error message",
      "Use type to change the input mode (text, email, password, number, search, etc.)",
      "Set invalid for error state styling without a form validation message",
      "Use name for native form submission"
    ],
    "children": {
      "allowed": false
    }
  }
}
