{
  "$schema": "../../../ui/designTokens/designTokens.schema.json",
  "prefix": "checkbox",
  "tokens": {
    "size": {
      "sm": {
        "width": "{core.spacing.size.06}",
        "height": "{core.spacing.size.06}",
        "iconSize": "{core.spacing.size.05}"
      },
      "md": {
        "width": "{core.spacing.size.07}",
        "height": "{core.spacing.size.07}",
        "iconSize": "{core.spacing.size.06}"
      },
      "lg": {
        "width": "{core.spacing.size.07}",
        "height": "{core.spacing.size.07}",
        "iconSize": "{core.spacing.size.07}"
      }
    },
    "color": {
      "background": {
        "default": "{semantic.color.background.primary}",
        "checked": "{semantic.color.action.background.primary.default}",
        "indeterminate": "{semantic.color.action.background.primary.default}",
        "disabled": "{color.background.disabled}"
      },
      "border": {
        "default": "{color.border.default}",
        "hover": "{color.border.hover}",
        "focus": "{color.border.focus}",
        "checked": "{semantic.color.action.background.primary.default}",
        "disabled": "{color.border.disabled}"
      },
      "icon": {
        "default": "{color.foreground.onBrand}",
        "disabled": "{color.foreground.disabled}"
      }
    },
    "border": {
      "width": "{core.shape.border.width.hairline}",
      "radius": "{core.shape.radius.small}"
    },
    "spacing": {
      "gap": "{core.spacing.size.04}"
    },
    "transition": {
      "duration": "{core.motion.duration.short}",
      "easing": "{core.motion.easing.standard}"
    },
    "focus": {
      "ring": {
        "width": "{interaction.focus.ringWidth}",
        "color": "{semantic.color.border.focus}",
        "offset": "{interaction.focus.ringOffset}"
      }
    }
  }
}
