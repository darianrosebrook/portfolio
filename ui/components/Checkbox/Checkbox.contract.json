{
  "name": "Checkbox",
  "layer": "primitive",
  "anatomy": [
    "root",
    "indicator",
    "checkboxWrapper",
    "checkIcon",
    "indeterminateIcon",
    "checkboxIndicator"
  ],
  "variants": {
    "size": [
      "sm",
      "md",
      "lg"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "disabled"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"checkbox\"]"
    },
    "input": {
      "required": true,
      "selector": "[data-slot=\"checkbox-input\"]"
    },
    "indicator": {
      "required": true,
      "selector": "[data-slot=\"checkbox-indicator\"]"
    }
  },
  "a11y": {
    "role": "generic",
    "labeling": [
      "aria-checked"
    ],
    "keyboard": [],
    "apgPattern": null
  },
  "tokens": {
    "root": {
      "checkbox.size.sm.width": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "layer": "core"
      },
      "checkbox.size.sm.height": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "layer": "core"
      },
      "checkbox.size.sm.iconSize": {
        "resolvesTo": "core.spacing.size.05",
        "fallback": "12px",
        "layer": "core"
      },
      "checkbox.size.md.width": {
        "resolvesTo": "core.spacing.size.07",
        "fallback": "24px",
        "layer": "core"
      },
      "checkbox.size.md.height": {
        "resolvesTo": "core.spacing.size.07",
        "fallback": "24px",
        "layer": "core"
      },
      "checkbox.size.md.iconSize": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "layer": "core"
      },
      "checkbox.size.lg.width": {
        "resolvesTo": "core.spacing.size.07",
        "fallback": "24px",
        "layer": "core"
      },
      "checkbox.size.lg.height": {
        "resolvesTo": "core.spacing.size.07",
        "fallback": "24px",
        "layer": "core"
      },
      "checkbox.size.lg.iconSize": {
        "resolvesTo": "core.spacing.size.07",
        "fallback": "24px",
        "layer": "core"
      },
      "checkbox.color.background.default": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "property": "background-color",
        "layer": "semantic"
      },
      "checkbox.color.background.checked": {
        "resolvesTo": "semantic.color.action.background.primary.default",
        "fallback": "#d9292b",
        "property": "background-color",
        "layer": "semantic"
      },
      "checkbox.color.background.indeterminate": {
        "resolvesTo": "semantic.color.action.background.primary.default",
        "fallback": "#d9292b",
        "property": "background-color",
        "layer": "semantic"
      },
      "checkbox.color.background.disabled": {
        "resolvesTo": "semantic.color.background.disabled",
        "fallback": "#cecece",
        "property": "background-color",
        "layer": "semantic"
      },
      "checkbox.color.border.default": {
        "resolvesTo": "semantic.color.border.default",
        "fallback": "#aeaeae",
        "property": "border-color",
        "layer": "semantic"
      },
      "checkbox.color.border.hover": {
        "resolvesTo": "semantic.color.border.hover",
        "fallback": "#f29495",
        "property": "border-color",
        "layer": "semantic"
      },
      "checkbox.color.border.focus": {
        "resolvesTo": "semantic.color.border.focus",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      },
      "checkbox.color.border.checked": {
        "resolvesTo": "semantic.color.action.background.primary.default",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      },
      "checkbox.color.border.disabled": {
        "resolvesTo": "semantic.color.border.disabled",
        "fallback": "#cecece",
        "property": "border-color",
        "layer": "semantic"
      },
      "checkbox.color.icon.default": {
        "resolvesTo": "semantic.color.foreground.on.brand",
        "fallback": "#ffffff",
        "layer": "semantic"
      },
      "checkbox.color.icon.disabled": {
        "resolvesTo": "semantic.color.foreground.disabled",
        "fallback": "#aeaeae",
        "layer": "semantic"
      },
      "checkbox.border.width": {
        "resolvesTo": "core.shape.border.width.hairline",
        "fallback": "1px",
        "property": "border-width",
        "layer": "core"
      },
      "checkbox.border.radius": {
        "resolvesTo": "core.shape.radius.small",
        "fallback": "4px",
        "property": "border-radius",
        "layer": "core"
      },
      "checkbox.spacing.gap": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "gap",
        "layer": "core"
      },
      "checkbox.transition.duration": {
        "resolvesTo": "core.motion.duration.short",
        "fallback": "150ms",
        "property": "transition-duration",
        "layer": "core"
      },
      "checkbox.transition.easing": {
        "resolvesTo": "core.motion.easing.standard",
        "fallback": "cubic-bezier(0.4, 0, 0.2, 1)",
        "property": "transition-timing-function",
        "layer": "core"
      },
      "checkbox.focus.ring.width": {
        "resolvesTo": "semantic.interaction.focus.ring.width",
        "fallback": "2px",
        "layer": "semantic"
      },
      "checkbox.focus.ring.color": {
        "resolvesTo": "semantic.color.border.focus",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "checkbox.focus.ring.offset": {
        "resolvesTo": "semantic.interaction.focus.ring.offset",
        "fallback": "2px",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        { "name": "size", "type": "CheckboxSize | undefined", "description": "Visual size variant: sm, md (default), or lg. Scales the checkbox dimensions via design tokens.", "required": false, "default": "md" },
        { "name": "checked", "type": "boolean | undefined", "description": "Controlled checked state. Pair with onChange for controlled mode.", "required": false },
        { "name": "defaultChecked", "type": "boolean | undefined", "description": "Uncontrolled initial checked state.", "required": false },
        { "name": "indeterminate", "type": "boolean | undefined", "description": "Renders the checkbox in an indeterminate state, typically used in select-all patterns where some but not all items are selected.", "required": false },
        { "name": "disabled", "type": "boolean | undefined", "description": "Prevents interaction and applies disabled styling.", "required": false }
      ]
    },
    "passthrough": {
      "extends": "input"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "focus": {
    "strategy": "auto",
    "description": "Native checkbox receives focus via Tab. No custom roving or trap needed."
  },
  "relationships": [
    {
      "from": "input",
      "to": "indicator",
      "attribute": "aria-hidden",
      "description": "The visual indicator div is aria-hidden so screen readers use only the native input's state."
    }
  ],
  "channels": {
    "checked": {
      "description": "Whether the checkbox is checked. Supports indeterminate state for partial selection.",
      "value": "checked",
      "defaultValue": "defaultChecked",
      "onChange": "onChange",
      "valueType": "boolean | \"indeterminate\""
    }
  },
  "form": {
    "participates": true,
    "inputType": "checkbox",
    "name": {
      "prop": "name"
    },
    "serialization": {
      "valueType": "string",
      "valueSource": "prop:value",
      "omitWhen": "unchecked",
      "multiple": false
    },
    "validity": {
      "model": "native",
      "ariaAttributes": [
        "aria-invalid",
        "aria-required",
        "aria-describedby"
      ]
    },
    "labeling": {
      "strategy": "associated-label",
      "required": true,
      "via": [
        "prop:label",
        "aria-labelledby",
        "aria-label"
      ]
    }
  },
  "description": "Binary or tri-state input for boolean selection. Supports indeterminate state for partial group selection.",
  "a2ui": {
    "category": "form-field",
    "usageHints": [
      "Use checked and onChange for controlled mode; defaultChecked for uncontrolled",
      "Set indeterminate for parent checkboxes in a group where some children are checked",
      "Always pair with a label — either via prop:label or a visible sibling Label component",
      "Use name and value for native form submission"
    ],
    "children": {
      "allowed": false
    }
  }
}
