{
  "name": "AnimatedText",
  "layer": "primitive",
  "anatomy": [
    "root",
    "animatedText",
    "word"
  ],
  "variants": {
    "as": [
      "h1",
      "h2",
      "h3",
      "h4",
      "h5",
      "h6",
      "p",
      "span",
      "div"
    ],
    "variant": [
      "blur-in",
      "fade-up",
      "slide-in"
    ]
  },
  "states": [
    "default"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"animated-text\"]"
    }
  },
  "a11y": {
    "role": "generic",
    "labeling": [],
    "keyboard": [],
    "apgPattern": null
  },
  "tokens": {},
  "props": {
    "designed": {
      "members": [
        {
          "name": "text",
          "type": "string",
          "description": "The text content to animate",
          "required": true
        },
        {
          "name": "as",
          "type": "\"h1\" | \"h2\" | \"h3\" | \"h4\" | \"h5\" | \"h6\" | \"p\" | \"span\" | \"div\" | undefined",
          "description": "Element type to render",
          "required": false
        },
        {
          "name": "variant",
          "type": "\"blur-in\" | \"fade-up\" | \"slide-in\" | undefined",
          "description": "Animation variant",
          "required": false
        },
        {
          "name": "duration",
          "type": "number | undefined",
          "description": "Duration of each word animation in seconds",
          "required": false
        },
        {
          "name": "stagger",
          "type": "number | undefined",
          "description": "Stagger delay between words in seconds",
          "required": false
        },
        {
          "name": "delay",
          "type": "number | undefined",
          "description": "Delay before animation starts in seconds",
          "required": false
        },
        {
          "name": "triggerOnScroll",
          "type": "boolean | undefined",
          "description": "Whether to trigger on scroll into view",
          "required": false
        },
        {
          "name": "scrollStart",
          "type": "string | undefined",
          "description": "ScrollTrigger start position",
          "required": false
        }
      ]
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "Character/line animation is skipped and text is shown fully visible immediately when prefers-reduced-motion is set.",
    "transitions": [
      {
        "name": "enter",
        "trigger": "visibility=offscreen\u2192visible",
        "phase": "enter",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasizedOut"
      }
    ]
  },
  "description": "Text that animates character-by-character or line-by-line into view on scroll.",
  "a2ui": {
    "category": "animation",
    "usageHints": [
      "Use for hero headings or pull-quotes where character animation adds visual impact",
      "Avoid on body text \u2014 animation per-character is distracting at scale",
      "Respects prefers-reduced-motion"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "string"
      ]
    }
  }
}
