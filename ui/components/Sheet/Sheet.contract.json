{
  "name": "Sheet",
  "layer": "composer",
  "anatomy": [
    "root",
    "body",
    "close",
    "content",
    "description",
    "footer",
    "header",
    "overlay",
    "portal",
    "title",
    "trigger",
    "modal"
  ],
  "variants": {
    "side": [
      "top",
      "right",
      "bottom",
      "left"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "open",
    "closed"
  ],
  "slots": {
    "body": {
      "required": false,
      "selector": "[data-slot=\"sheet-body\"]"
    },
    "close": {
      "required": false,
      "selector": "[data-slot=\"sheet-close\"]"
    },
    "content": {
      "required": false,
      "selector": "[data-slot=\"sheet-content\"]"
    },
    "description": {
      "required": false,
      "selector": "[data-slot=\"sheet-description\"]"
    },
    "footer": {
      "required": false,
      "selector": "[data-slot=\"sheet-footer\"]"
    },
    "header": {
      "required": false,
      "selector": "[data-slot=\"sheet-header\"]"
    },
    "overlay": {
      "required": false,
      "selector": "[data-slot=\"sheet-overlay\"]"
    },
    "portal": {
      "required": false
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"sheet\"]"
    },
    "title": {
      "required": false,
      "selector": "[data-slot=\"sheet-title\"]"
    },
    "trigger": {
      "required": false,
      "selector": "[data-slot=\"sheet-trigger\"]"
    }
  },
  "a11y": {
    "role": "dialog",
    "labeling": [
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "Enter|Space",
        "when": "trigger",
        "then": "activate"
      },
      {
        "key": "Escape",
        "when": "open",
        "then": "close"
      },
      {
        "key": "Tab",
        "when": "open",
        "then": "cycle focus within"
      }
    ],
    "apgPattern": "dialog-modal"
  },
  "tokens": {
    "root": {
      "sheet.color.overlay": {
        "resolvesTo": "semantic.overlay.scrim.sheet",
        "fallback": "rgba(0,0,0,0.50)",
        "layer": "semantic"
      },
      "sheet.color.background": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "property": "background-color",
        "layer": "semantic"
      },
      "sheet.color.backgroundHover": {
        "resolvesTo": "semantic.interaction.background.hover",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "sheet.color.border": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "property": "border-color",
        "layer": "semantic"
      },
      "sheet.color.borderLight": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "property": "border-color",
        "layer": "semantic"
      },
      "sheet.color.text": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "sheet.color.textTitle": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "sheet.color.textDescription": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "sheet.color.textMuted": {
        "resolvesTo": "semantic.color.foreground.tertiary",
        "fallback": "#717171",
        "property": "color",
        "layer": "semantic"
      },
      "sheet.border.width": {
        "resolvesTo": "core.shape.border.width.hairline",
        "fallback": "1px",
        "property": "border-width",
        "layer": "core"
      },
      "sheet.border.radius": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "sheet.border.radiusClose": {
        "resolvesTo": "core.shape.radius.small",
        "fallback": "4px",
        "property": "border-radius",
        "layer": "core"
      },
      "sheet.size.width": {
        "literal": "400px",
        "property": "min-width"
      },
      "sheet.size.height": {
        "literal": "300px",
        "property": "min-height"
      },
      "sheet.size.close": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "layer": "core"
      },
      "sheet.spacing.padding": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "padding",
        "layer": "core"
      },
      "sheet.spacing.gap": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "gap",
        "layer": "core"
      },
      "sheet.spacing.section": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "layer": "core"
      },
      "sheet.spacing.headerGap": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "property": "gap",
        "layer": "core"
      },
      "sheet.spacing.footerGap": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "property": "gap",
        "layer": "core"
      },
      "sheet.spacing.closeOffset": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "layer": "core"
      },
      "sheet.text.size": {
        "resolvesTo": "semantic.typography.body.02",
        "fallback": "16px",
        "property": "font-size",
        "layer": "semantic"
      },
      "sheet.text.lineHeight": {
        "resolvesTo": "semantic.typography.line.height.normal",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      },
      "sheet.text.sizeTitle": {
        "resolvesTo": "semantic.typography.heading.06",
        "fallback": "14px",
        "property": "font-size",
        "layer": "semantic"
      },
      "sheet.text.lineHeightTitle": {
        "resolvesTo": "semantic.typography.line.height.tight",
        "fallback": "1.2",
        "property": "line-height",
        "layer": "semantic"
      },
      "sheet.text.weightTitle": {
        "resolvesTo": "semantic.typography.font.weight.medium",
        "fallback": "500",
        "property": "font-weight",
        "layer": "semantic"
      },
      "sheet.text.sizeDescription": {
        "resolvesTo": "semantic.typography.body.03",
        "fallback": "14px",
        "property": "font-size",
        "layer": "semantic"
      },
      "sheet.text.lineHeightDescription": {
        "resolvesTo": "semantic.typography.line.height.loose",
        "fallback": "1.8",
        "property": "line-height",
        "layer": "semantic"
      },
      "sheet.motion.duration": {
        "resolvesTo": "core.motion.duration.medium",
        "fallback": "250ms",
        "property": "transition-duration",
        "layer": "core"
      },
      "sheet.motion.easing": {
        "resolvesTo": "core.motion.easing.standard",
        "fallback": "cubic-bezier(0.4, 0, 0.2, 1)",
        "property": "transition-timing-function",
        "layer": "core"
      },
      "sheet.zIndex.overlay": {
        "resolvesTo": "core.layer.component",
        "fallback": "50",
        "layer": "core"
      },
      "sheet.zIndex.content": {
        "resolvesTo": "core.layer.above",
        "fallback": "51",
        "layer": "core"
      },
      "sheet.shadow": {
        "resolvesTo": "semantic.elevation.surface.floating",
        "fallback": "[object Object]",
        "property": "box-shadow",
        "layer": "semantic"
      },
      "sheet.focus.width": {
        "resolvesTo": "core.shape.border.width.thick",
        "fallback": "2px",
        "layer": "core"
      },
      "sheet.focus.color": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "sheet.focus.offset": {
        "resolvesTo": "core.spacing.size.01",
        "fallback": "1px",
        "layer": "core"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "defaultOpen",
          "type": "boolean | undefined",
          "description": "defaultOpen prop for Sheet.",
          "required": false
        },
        {
          "name": "open",
          "type": "boolean | undefined",
          "description": "open prop for Sheet.",
          "required": false
        },
        {
          "name": "side",
          "type": "SheetSide | undefined",
          "description": "side prop for Sheet.",
          "required": false
        },
        {
          "name": "modal",
          "type": "boolean | undefined",
          "description": "modal prop for Sheet.",
          "required": false
        },
        {
          "name": "title",
          "type": "string | undefined",
          "description": "title prop for Sheet.",
          "required": false
        }
      ]
    },
    "passthrough": {
      "extends": "div"
    }
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "Duration set to 0; panel appears/disappears instantly without slide animation.",
    "transitions": [
      {
        "name": "open",
        "trigger": "openness=closed\u2192opening",
        "phase": "enter",
        "properties": [
          "transform"
        ],
        "duration": "sheet.motion.duration",
        "easing": "sheet.motion.easing"
      },
      {
        "name": "close",
        "trigger": "openness=open\u2192closing",
        "phase": "exit",
        "properties": [
          "transform"
        ],
        "duration": "sheet.motion.duration",
        "easing": "sheet.motion.easing"
      }
    ]
  },
  "focus": {
    "strategy": "trap",
    "initialFocus": "content",
    "returnFocus": "trigger",
    "scrollLock": true,
    "wrap": true
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "positioning": "anchored",
    "layering": "modal",
    "backdrop": true
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape",
        "defaultEnabled": true,
        "description": "Closes the sheet and returns focus to the trigger element."
      },
      {
        "event": "overlayClick",
        "defaultEnabled": true,
        "description": "Clicking outside the sheet panel closes it."
      }
    ]
  },
  "relationships": [
    {
      "from": "root",
      "to": "title",
      "attribute": "aria-labelledby",
      "description": "Sheet dialog takes its accessible name from its title element."
    }
  ],
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "channels": {
    "openness": {
      "description": "Whether the sheet panel is open.",
      "value": "open",
      "defaultValue": "defaultOpen",
      "onChange": "onOpenChange",
      "valueType": "boolean"
    }
  },
  "description": "Slide-in panel (drawer) that overlays the page from an edge. Traps focus until dismissed.",
  "a2ui": {
    "category": "overlay",
    "usageHints": [
      "Use side to control which edge the sheet slides in from (left, right, top, bottom)",
      "Bind open and onOpenChange to control visibility",
      "Sheet traps focus while open; Escape or clicking the overlay closes it by default",
      "Prefer Dialog for centered confirmations; use Sheet for detail panels, filters, or nav drawers"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "node-ref"
      ]
    }
  }
}
