{
  "name": "Spinner",
  "layer": "primitive",
  "anatomy": [
    "root",
    "inline",
    "visual"
  ],
  "variants": {
    "size": [
      "xs",
      "sm",
      "md",
      "lg"
    ],
    "variant": [
      "ring",
      "dots",
      "bars"
    ],
    "thickness": [
      "hairline",
      "regular",
      "bold"
    ]
  },
  "states": [
    "default"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"spinner\"]"
    },
    "visual": {
      "required": true,
      "selector": "[data-slot=\"spinner-visual\"]"
    }
  },
  "a11y": {
    "role": "generic",
    "labeling": [
      "aria-label"
    ],
    "keyboard": [],
    "apgPattern": null
  },
  "tokens": {
    "root": {
      "spinner.size.xs": {
        "literal": "12px"
      },
      "spinner.size.sm": {
        "literal": "16px"
      },
      "spinner.size.md": {
        "literal": "20px"
      },
      "spinner.size.lg": {
        "literal": "28px"
      },
      "spinner.thickness.hairline": {
        "literal": "2px"
      },
      "spinner.thickness.regular": {
        "literal": "3px"
      },
      "spinner.thickness.bold": {
        "literal": "4px"
      },
      "spinner.color.accent": {
        "resolvesTo": "semantic.color.background.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "spinner.color.track": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "layer": "semantic"
      },
      "spinner.dots.gap": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "gap",
        "layer": "core"
      },
      "spinner.anim.duration": {
        "literal": "800ms",
        "property": "transition-duration"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "thickness",
          "type": "number | \"hairline\" | \"regular\" | \"bold\" | undefined",
          "description": "Stroke thickness token or px. Default: 'regular'",
          "required": false
        },
        {
          "name": "variant",
          "type": "SpinnerVariant | undefined",
          "description": "Visual variant",
          "required": false
        },
        {
          "name": "ariaHidden",
          "type": "boolean | undefined",
          "description": "If decorative only, set ariaHidden; else provide label",
          "required": false
        },
        {
          "name": "label",
          "type": "string | undefined",
          "description": "Localized label for SR users; ignored if ariaHidden",
          "required": false
        },
        {
          "name": "inline",
          "type": "boolean | undefined",
          "description": "Inline layout (align with baseline)",
          "required": false
        },
        {
          "name": "showAfterMs",
          "type": "number | undefined",
          "description": "Delay before showing (ms) to avoid spinner flash",
          "required": false
        },
        {
          "name": "defaultValue",
          "type": "string | number | readonly string[] | undefined",
          "description": "defaultValue prop for Spinner.",
          "required": false
        },
        {
          "name": "title",
          "type": "string | undefined",
          "description": "title prop for Spinner.",
          "required": false
        }
      ]
    },
    "passthrough": {
      "extends": "div"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "description": "Rotating indicator for indeterminate loading states.",
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Add aria-label when the spinner is the only loading indicator visible",
      "Use size to match the spinner to its surrounding context",
      "Use thickness to adjust visual weight (hairline for subtle, bold for prominent)",
      "Prefer Skeleton for content areas; use Spinner for button or icon loading states"
    ],
    "children": {
      "allowed": false
    }
  }
}
