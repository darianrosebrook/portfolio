{
  "name": "Skeleton",
  "layer": "primitive",
  "anatomy": [
    "root",
    "stack",
    "row",
    "shape",
    "kind-circle",
    "kind-line"
  ],
  "variants": {
    "variant": [
      "block",
      "text",
      "avatar",
      "media",
      "dataviz",
      "actions"
    ],
    "animate": [
      "shimmer",
      "wipe",
      "pulse",
      "none"
    ],
    "density": [
      "compact",
      "regular",
      "spacious"
    ]
  },
  "states": [
    "default"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"skeleton\"]"
    }
  },
  "a11y": {
    "role": "generic",
    "labeling": [
      "aria-label"
    ],
    "keyboard": [],
    "apgPattern": null
  },
  "tokens": {
    "root": {
      "skeleton.color.base": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "layer": "semantic"
      },
      "skeleton.color.highlight": {
        "resolvesTo": "semantic.color.background.highlight",
        "fallback": "#f7c1c2",
        "layer": "semantic"
      },
      "skeleton.color.highlight-2": {
        "resolvesTo": "semantic.color.status.info",
        "fallback": "#0a65fe",
        "layer": "semantic"
      },
      "skeleton.color.static": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "layer": "semantic"
      },
      "skeleton.color.contrast-base": {
        "resolvesTo": "semantic.color.border.primary",
        "fallback": "#f29495",
        "layer": "semantic"
      },
      "skeleton.radius.sm": {
        "resolvesTo": "core.shape.radius.02",
        "fallback": "4px",
        "property": "border-radius",
        "layer": "core"
      },
      "skeleton.radius.md": {
        "resolvesTo": "core.shape.radius.03",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "skeleton.radius.lg": {
        "resolvesTo": "core.shape.radius.04",
        "fallback": "16px",
        "property": "border-radius",
        "layer": "core"
      },
      "skeleton.gap.sm": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "property": "gap",
        "layer": "core"
      },
      "skeleton.gap.md": {
        "resolvesTo": "core.spacing.size.05",
        "fallback": "12px",
        "property": "gap",
        "layer": "core"
      },
      "skeleton.gap.lg": {
        "resolvesTo": "core.spacing.size.07",
        "fallback": "24px",
        "property": "gap",
        "layer": "core"
      },
      "skeleton.anim.duration": {
        "resolvesTo": "core.motion.duration.long",
        "fallback": "400ms",
        "property": "transition-duration",
        "layer": "core"
      },
      "skeleton.anim.duration-alt": {
        "resolvesTo": "core.motion.duration.long",
        "fallback": "400ms",
        "property": "transition-duration",
        "layer": "core"
      },
      "skeleton.anim.duration-pulse": {
        "resolvesTo": "core.motion.duration.medium",
        "fallback": "250ms",
        "property": "transition-duration",
        "layer": "core"
      },
      "skeleton.anim.easing": {
        "resolvesTo": "core.motion.easing.standard",
        "fallback": "cubic-bezier(0.4, 0, 0.2, 1)",
        "property": "transition-timing-function",
        "layer": "core"
      }
    }
  },
  "props": {
    "styled": {
      "members": [
        {
          "name": "variant",
          "type": "SkeletonVariant | undefined",
          "description": "",
          "required": false,
          "default": "block"
        },
        {
          "name": "animate",
          "type": "\"shimmer\" | \"wipe\" | \"pulse\" | \"none\" | undefined",
          "description": "",
          "required": false,
          "default": "shimmer"
        },
        {
          "name": "density",
          "type": "\"compact\" | \"regular\" | \"spacious\" | undefined",
          "description": "",
          "required": false,
          "default": "regular"
        },
        {
          "name": "aspectRatio",
          "type": "string | undefined",
          "description": "",
          "required": false
        },
        {
          "name": "lines",
          "type": "number | { min: number; max: number; } | undefined",
          "description": "",
          "required": false,
          "default": "{ min: 2, max: 3 }"
        },
        {
          "name": "radius",
          "type": "\"sm\" | \"md\" | \"lg\" | undefined",
          "description": "",
          "required": false
        },
        {
          "name": "decorative",
          "type": "boolean | undefined",
          "description": "",
          "required": false,
          "default": "true"
        }
      ]
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "description": "Loading placeholder that mimics the shape of content before data is available.",
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Match the width and height to the content it replaces to minimize layout shift",
      "Use animate to select the loading animation (shimmer, pulse, wipe, or none)",
      "Use density to match the spacing of the surrounding content",
      "Remove Skeleton and render real content once data is loaded"
    ],
    "children": {
      "allowed": false
    }
  }
}
