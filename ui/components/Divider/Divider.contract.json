{
  "name": "Divider",
  "layer": "primitive",
  "anatomy": [
    "root"
  ],
  "variants": {
    "orientation": [
      "horizontal",
      "vertical"
    ]
  },
  "states": [
    "default"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"divider\"]"
    }
  },
  "a11y": {
    "role": "generic",
    "labeling": [
      "aria-orientation"
    ],
    "keyboard": [],
    "apgPattern": null
  },
  "tokens": {
    "root": {
      "divider.color.default": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "layer": "semantic"
      },
      "divider.color.subtle": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "layer": "semantic"
      },
      "divider.color.muted": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "layer": "semantic"
      },
      "divider.size.thickness": {
        "resolvesTo": "core.shape.border.width.hairline",
        "fallback": "1px",
        "layer": "core"
      },
      "divider.size.thicknessThick": {
        "resolvesTo": "core.shape.border.width.hairline",
        "fallback": "1px",
        "layer": "core"
      },
      "divider.spacing.margin": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "layer": "core"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "orientation",
          "type": "\"horizontal\" | \"vertical\" | undefined",
          "description": "Visual orientation of the divider",
          "required": false
        },
        {
          "name": "decorative",
          "type": "boolean | undefined",
          "description": "Semantic role - separator (default) or presentation for purely decorative",
          "required": false
        },
        {
          "name": "thickness",
          "type": "string | undefined",
          "description": "Custom thickness/size",
          "required": false
        },
        {
          "name": "defaultValue",
          "type": "string | number | readonly string[] | undefined",
          "description": "defaultValue prop for Divider.",
          "required": false
        },
        {
          "name": "title",
          "type": "string | undefined",
          "description": "title prop for Divider.",
          "required": false
        }
      ]
    },
    "passthrough": {
      "extends": "hr"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "description": "Visual separator between content sections. Renders as an hr or div depending on orientation.",
  "a2ui": {
    "category": "layout",
    "usageHints": [
      "Use orientation=horizontal for horizontal rules; orientation=vertical for column separators",
      "Do not place Divider inside flex-row containers unless you set an explicit height"
    ],
    "children": {
      "allowed": false
    }
  }
}
