{
  "name": "Details",
  "layer": "composer",
  "anatomy": [
    "root",
    "compact",
    "inline",
    "summary",
    "summaryContent",
    "icon",
    "summaryText",
    "content"
  ],
  "variants": {
    "variant": [
      "default",
      "inline",
      "compact"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "disabled",
    "open",
    "closed"
  ],
  "slots": {
    "compact": {
      "required": false
    },
    "inline": {
      "required": false
    }
  },
  "a11y": {
    "role": "group",
    "labeling": [
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "KeyboardEvent",
        "when": "root",
        "then": "handled by component"
      }
    ],
    "apgPattern": null
  },
  "tokens": {
    "root": {
      "details.size.padding.default": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "padding",
        "layer": "core"
      },
      "details.size.radius.default": {
        "resolvesTo": "semantic.shape.control.radius.default",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "semantic"
      },
      "details.size.icon": {
        "resolvesTo": "core.spacing.size.05",
        "fallback": "12px",
        "layer": "core"
      },
      "details.color.background.default": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "property": "background-color",
        "layer": "semantic"
      },
      "details.color.background.subtle": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "details.color.background.hover": {
        "resolvesTo": "semantic.color.background.hover",
        "fallback": "#cecece",
        "property": "background-color",
        "layer": "semantic"
      },
      "details.color.background.code": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "details.color.foreground.primary": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "details.color.foreground.secondary": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "details.color.border.default": {
        "resolvesTo": "semantic.color.border.primary",
        "fallback": "#f29495",
        "property": "border-color",
        "layer": "semantic"
      },
      "details.color.border.hover": {
        "resolvesTo": "semantic.color.border.bold",
        "fallback": "#8f8f8f",
        "property": "border-color",
        "layer": "semantic"
      },
      "details.color.border.accent": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      },
      "details.focus.ring.width": {
        "resolvesTo": "core.shape.border.width.thick",
        "fallback": "2px",
        "layer": "core"
      },
      "details.focus.ring.color": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "details.focus.ring.offset": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "layer": "core"
      },
      "details.motion.duration.fast": {
        "resolvesTo": "core.motion.duration.short",
        "fallback": "150ms",
        "property": "transition-duration",
        "layer": "core"
      },
      "details.motion.easing.standard": {
        "resolvesTo": "core.motion.easing.standard",
        "fallback": "cubic-bezier(0.4, 0, 0.2, 1)",
        "property": "transition-timing-function",
        "layer": "core"
      },
      "details.spacing.gap.default": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "property": "gap",
        "layer": "core"
      },
      "details.spacing.padding.left": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "padding",
        "layer": "core"
      },
      "details.spacing.margin.bottom": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "layer": "core"
      },
      "details.spacing.margin.top": {
        "resolvesTo": "core.spacing.size.01",
        "fallback": "1px",
        "layer": "core"
      },
      "details.spacing.margin.compact": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "layer": "core"
      },
      "details.typography.lineHeight.body": {
        "resolvesTo": "semantic.typography.line.height.body",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      },
      "details.typography.lineHeight.tight": {
        "resolvesTo": "semantic.typography.line.height.tight",
        "fallback": "1.2",
        "property": "line-height",
        "layer": "semantic"
      },
      "details.typography.fontWeight.medium": {
        "resolvesTo": "semantic.typography.font.weight.medium",
        "fallback": "500",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "styled": {
      "members": [
        {
          "name": "summary",
          "type": "string",
          "description": "The summary text displayed in the toggle button",
          "required": true
        },
        {
          "name": "variant",
          "type": "\"default\" | \"inline\" | \"compact\" | undefined",
          "description": "Visual variant - replaces boolean props",
          "required": false,
          "default": "default"
        },
        {
          "name": "icon",
          "type": "\"left\" | \"right\" | \"none\" | undefined",
          "description": "Icon configuration - replaces showIcon + iconPosition booleans",
          "required": false,
          "default": "left"
        },
        {
          "name": "open",
          "type": "boolean | undefined",
          "description": "Controlled open state",
          "required": false
        },
        {
          "name": "defaultOpen",
          "type": "boolean | undefined",
          "description": "Default open state for uncontrolled",
          "required": false
        },
        {
          "name": "disabled",
          "type": "boolean | undefined",
          "description": "Disabled state",
          "required": false
        }
      ]
    },
    "hook": {
      "members": [
        {
          "name": "open",
          "type": "boolean | undefined",
          "description": "Controlled open state",
          "required": false
        },
        {
          "name": "defaultOpen",
          "type": "boolean | undefined",
          "description": "Default open state for uncontrolled",
          "required": false
        },
        {
          "name": "disabled",
          "type": "boolean | undefined",
          "description": "Disabled state",
          "required": false
        }
      ]
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": true
  }
}
