{
  "name": "Details",
  "layer": "composer",
  "anatomy": [
    "root",
    "compact",
    "inline",
    "summary",
    "summaryContent",
    "icon",
    "summaryText",
    "content"
  ],
  "variants": {
    "variant": [
      "default",
      "inline",
      "compact"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "disabled",
    "open",
    "closed"
  ],
  "slots": {
    "compact": {
      "required": false
    },
    "inline": {
      "required": false
    }
  },
  "a11y": {
    "role": "group",
    "labeling": [
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "KeyboardEvent",
        "when": "root",
        "then": "handled by component"
      }
    ],
    "apgPattern": null
  },
  "tokens": {
    "root": [
      "details.size.padding.default",
      "details.size.radius.default",
      "details.size.icon",
      "details.color.background.default",
      "details.color.background.subtle",
      "details.color.background.hover",
      "details.color.background.code",
      "details.color.foreground.primary",
      "details.color.foreground.secondary",
      "details.color.border.default",
      "details.color.border.hover",
      "details.color.border.accent",
      "details.focus.ring.width",
      "details.focus.ring.color",
      "details.focus.ring.offset",
      "details.motion.duration.fast",
      "details.motion.easing.standard",
      "details.spacing.gap.default",
      "details.spacing.padding.left",
      "details.spacing.margin.bottom",
      "details.spacing.margin.top",
      "details.spacing.margin.compact",
      "details.typography.lineHeight.body",
      "details.typography.lineHeight.tight",
      "details.typography.fontWeight.medium"
    ]
  },
  "props": {
    "styled": {
      "members": [
        {
          "name": "summary",
          "type": "string",
          "description": "The summary text displayed in the toggle button",
          "required": true
        },
        {
          "name": "variant",
          "type": "\"default\" | \"inline\" | \"compact\" | undefined",
          "description": "Visual variant - replaces boolean props",
          "required": false,
          "default": "default"
        },
        {
          "name": "icon",
          "type": "\"left\" | \"right\" | \"none\" | undefined",
          "description": "Icon configuration - replaces showIcon + iconPosition booleans",
          "required": false,
          "default": "left"
        },
        {
          "name": "open",
          "type": "boolean | undefined",
          "description": "Controlled open state",
          "required": false
        },
        {
          "name": "defaultOpen",
          "type": "boolean | undefined",
          "description": "Default open state for uncontrolled",
          "required": false
        },
        {
          "name": "disabled",
          "type": "boolean | undefined",
          "description": "Disabled state",
          "required": false
        }
      ]
    },
    "hook": {
      "members": [
        {
          "name": "open",
          "type": "boolean | undefined",
          "description": "Controlled open state",
          "required": false
        },
        {
          "name": "defaultOpen",
          "type": "boolean | undefined",
          "description": "Default open state for uncontrolled",
          "required": false
        },
        {
          "name": "disabled",
          "type": "boolean | undefined",
          "description": "Disabled state",
          "required": false
        }
      ]
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": true
  }
}
