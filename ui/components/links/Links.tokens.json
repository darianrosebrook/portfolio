{
  "$schema": "../../../ui/designTokens/designTokens.schema.json",
  "prefix": "links",
  "tokens": {
    "color": {
      "foreground": {
        "default": "{semantic.color.foreground.primary}",
        "hover": "{semantic.interaction.text.hover}",
        "active": "{semantic.interaction.text.active}",
        "visited": "{semantic.color.foreground.secondary}",
        "disabled": "{semantic.color.foreground.disabled}"
      },
      "underline": {
        "default": "{semantic.color.border.light}",
        "hover": "{semantic.interaction.border.hover}",
        "active": "{semantic.interaction.border.active}",
        "disabled": "{semantic.color.border.disabled}"
      }
    },
    "spacing": {
      "gap": {
        "default": "{core.spacing.size.02}",
        "small": "{core.spacing.size.01}",
        "large": "{core.spacing.size.03}"
      },
      "padding": {
        "default": "{core.spacing.size.02}",
        "small": "{core.spacing.size.01}",
        "large": "{core.spacing.size.03}"
      },
      "margin": {
        "default": "{core.spacing.size.02}",
        "small": "{core.spacing.size.01}",
        "large": "{core.spacing.size.03}"
      }
    },
    "typography": {
      "fontSize": {
        "small": "{semantic.typography.body.04}",
        "medium": "{semantic.typography.body.04}",
        "large": "{semantic.typography.body.03}"
      },
      "fontWeight": {
        "default": "{semantic.typography.fontWeight.regular}",
        "medium": "{semantic.typography.fontWeight.medium}",
        "semibold": "{semantic.typography.fontWeight.medium}"
      },
      "lineHeight": {
        "default": "{semantic.typography.lineHeight.normal}",
        "tight": "{semantic.typography.lineHeight.tight}",
        "relaxed": "{semantic.typography.lineHeight.loose}"
      }
    },
    "motion": {
      "duration": {
        "fast": "{core.motion.duration.short}",
        "normal": "{core.motion.duration.medium}",
        "slow": "{core.motion.duration.long}"
      },
      "easing": {
        "standard": "{core.motion.easing.standard}",
        "decelerate": "{core.motion.easing.emphasizedOut}",
        "accelerate": "{core.motion.easing.emphasizedIn}"
      }
    },
    "border": {
      "width": {
        "default": "{core.shape.border.width.hairline}",
        "thick": "{core.shape.border.width.hairline}"
      },
      "style": {
        "default": "{core.shape.border.style.solid}",
        "dashed": "{core.shape.border.style.dashed}",
        "dotted": "{core.shape.border.style.dotted}"
      }
    },
    "animation": {
      "stagger": {
        "default": "{core.motion.stagger.sm}",
        "fast": "{core.motion.stagger.xs}",
        "slow": "{core.motion.stagger.slow}"
      },
      "duration": {
        "default": "{core.motion.duration.long}",
        "fast": "{core.motion.duration.medium0}",
        "slow": "{core.motion.duration.long0}"
      }
    }
  }
}
