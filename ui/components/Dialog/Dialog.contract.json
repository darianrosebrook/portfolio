{
  "name": "Dialog",
  "layer": "composer",
  "anatomy": [
    "root",
    "body",
    "closeButton",
    "footer",
    "header",
    "title",
    "backdrop",
    "modal",
    "close"
  ],
  "variants": {
    "size": [
      "sm",
      "md",
      "lg",
      "xl",
      "full"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "active",
    "leaving"
  ],
  "slots": {
    "body": {
      "required": false
    },
    "closeButton": {
      "required": false
    },
    "footer": {
      "required": false
    },
    "header": {
      "required": false
    },
    "title": {
      "required": false
    }
  },
  "a11y": {
    "role": "dialog",
    "labeling": [
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "Enter|Space",
        "when": "trigger",
        "then": "activate"
      },
      {
        "key": "Escape",
        "when": "open",
        "then": "close"
      },
      {
        "key": "Tab",
        "when": "open",
        "then": "cycle focus within"
      }
    ],
    "apgPattern": "dialog-modal"
  },
