{
  "name": "Dialog",
  "layer": "composer",
  "anatomy": [
    "root",
    "body",
    "closeButton",
    "footer",
    "header",
    "title",
    "backdrop",
    "modal",
    "close"
  ],
  "variants": {
    "size": [
      "sm",
      "md",
      "lg",
      "xl",
      "full"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "active",
    "leaving"
  ],
  "slots": {
    "body": {
      "required": false
    },
    "closeButton": {
      "required": false
    },
    "footer": {
      "required": false
    },
    "header": {
      "required": false
    },
    "title": {
      "required": false
    }
  },
  "a11y": {
    "role": "dialog",
    "labeling": [
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "Enter|Space",
        "when": "trigger",
        "then": "activate"
      },
      {
        "key": "Escape",
        "when": "open",
        "then": "close"
      },
      {
        "key": "Tab",
        "when": "open",
        "then": "cycle focus within"
      }
    ],
    "apgPattern": "dialog-modal"
  },
  "tokens": {
    "root": [
      "dialog.color.background.default",
      "dialog.color.background.backdrop",
      "dialog.color.background.hover",
      "dialog.color.background.active",
      "dialog.color.foreground.default",
      "dialog.color.foreground.title",
      "dialog.color.foreground.secondary",
      "dialog.color.border.default",
      "dialog.color.border.focus",
      "dialog.size.sm.width.value",
      "dialog.size.sm.width.unit",
      "dialog.size.sm.maxWidth.value",
      "dialog.size.sm.maxWidth.unit",
      "dialog.size.sm.padding",
      "dialog.size.md.width.value",
      "dialog.size.md.width.unit",
      "dialog.size.md.maxWidth.value",
      "dialog.size.md.maxWidth.unit",
      "dialog.size.md.padding",
      "dialog.size.lg.width.value",
      "dialog.size.lg.width.unit",
      "dialog.size.lg.maxWidth.value",
      "dialog.size.lg.maxWidth.unit",
      "dialog.size.lg.padding",
      "dialog.size.xl.width.value",
      "dialog.size.xl.width.unit",
      "dialog.size.xl.maxWidth.value",
      "dialog.size.xl.maxWidth.unit",
      "dialog.size.xl.padding",
      "dialog.size.full.width.value",
      "dialog.size.full.width.unit",
      "dialog.size.full.height.value",
      "dialog.size.full.height.unit",
      "dialog.size.full.maxWidth.value",
      "dialog.size.full.maxWidth.unit",
      "dialog.size.full.padding",
      "dialog.size.radius.default",
      "dialog.size.radius.small",
      "dialog.size.closeButton.size",
      "dialog.size.closeButton.offset",
      "dialog.elevation.default",
      "dialog.spacing.backdrop.padding",
      "dialog.spacing.backdrop.paddingMobile",
      "dialog.spacing.header.paddingTop",
      "dialog.spacing.header.paddingRight",
      "dialog.spacing.header.paddingBottom",
      "dialog.spacing.header.paddingLeft",
      "dialog.spacing.header.paddingMobile",
      "dialog.spacing.body.paddingTop",
      "dialog.spacing.body.paddingRight",
      "dialog.spacing.body.paddingBottom",
      "dialog.spacing.body.paddingLeft",
      "dialog.spacing.body.paddingYMobile",
      "dialog.spacing.body.paddingXMobile",
      "dialog.spacing.footer.paddingTop",
      "dialog.spacing.footer.paddingRight",
      "dialog.spacing.footer.paddingBottom",
      "dialog.spacing.footer.paddingLeft",
      "dialog.spacing.footer.gap",
      "dialog.spacing.footer.gapMobile",
      "dialog.spacing.footer.paddingYMobile",
      "dialog.spacing.footer.paddingXMobile",
      "dialog.spacing.footer.paddingBottomMobile",
      "dialog.typography.title.fontSize",
      "dialog.typography.title.fontWeight",
      "dialog.typography.title.lineHeight",
      "dialog.motion.duration.enter",
      "dialog.motion.duration.exit",
      "dialog.motion.easing.enter",
      "dialog.motion.easing.exit"
    ],
    "body": [
      "dialog.spacing.body.paddingTop",
      "dialog.spacing.body.paddingRight",
      "dialog.spacing.body.paddingBottom",
      "dialog.spacing.body.paddingLeft",
      "dialog.spacing.body.paddingYMobile",
      "dialog.spacing.body.paddingXMobile"
    ],
    "closeButton": {
      "dialog.size.closeButton.size": {
        "resolvesTo": "core.spacing.size.08",
        "fallback": "32px",
        "layer": "core"
      },
      "dialog.size.closeButton.offset": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "layer": "core"
      }
    },
    "footer": [
      "dialog.spacing.footer.paddingTop",
      "dialog.spacing.footer.paddingRight",
      "dialog.spacing.footer.paddingBottom",
      "dialog.spacing.footer.paddingLeft",
      "dialog.spacing.footer.gap",
      "dialog.spacing.footer.gapMobile",
      "dialog.spacing.footer.paddingYMobile",
      "dialog.spacing.footer.paddingXMobile",
      "dialog.spacing.footer.paddingBottomMobile"
    ],
    "header": {
      "dialog.spacing.header.paddingTop": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "padding",
        "layer": "core"
      },
      "dialog.spacing.header.paddingRight": {
        "resolvesTo": "core.spacing.size.07",
        "fallback": "24px",
        "property": "padding",
        "layer": "core"
      },
      "dialog.spacing.header.paddingBottom": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "padding",
        "layer": "core"
      },
      "dialog.spacing.header.paddingLeft": {
        "resolvesTo": "core.spacing.size.07",
        "fallback": "24px",
        "property": "padding",
        "layer": "core"
      },
      "dialog.spacing.header.paddingMobile": {
        "resolvesTo": "core.spacing.size.05",
        "fallback": "12px",
        "property": "padding",
        "layer": "core"
      }
    },
    "title": {
      "dialog.typography.title.fontSize": {
        "resolvesTo": "semantic.typography.heading.04",
        "fallback": "18px",
        "layer": "semantic"
      },
      "dialog.typography.title.fontWeight": {
        "resolvesTo": "semantic.typography.font.weight.bold",
        "fallback": "700",
        "layer": "semantic"
      },
      "dialog.typography.title.lineHeight": {
        "resolvesTo": "semantic.typography.line.height.heading",
        "fallback": "1",
        "property": "line-height",
        "layer": "semantic"
      }
    },
    "backdrop": {
      "dialog.spacing.backdrop.padding": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "padding",
        "layer": "core"
      },
      "dialog.spacing.backdrop.paddingMobile": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "property": "padding",
        "layer": "core"
      }
    }
  },
  "props": {
    "styled": {
      "members": [
        {
          "name": "modal",
          "type": "boolean | undefined",
          "description": "Whether dialog is modal (blocks interaction with background)",
          "required": false
        },
        {
          "name": "size",
          "type": "DialogSize | undefined",
          "description": "Dialog size",
          "required": false
        },
        {
          "name": "closeOnBackdropClick",
          "type": "boolean | undefined",
          "description": "Whether to close on backdrop click (modal only)",
          "required": false
        },
        {
          "name": "closeOnEscape",
          "type": "boolean | undefined",
          "description": "Whether to close on escape key",
          "required": false
        },
        {
          "name": "initialFocus",
          "type": "string | undefined",
          "description": "Initial focus element selector",
          "required": false
        },
        {
          "name": "returnFocus",
          "type": "string | undefined",
          "description": "Return focus element selector",
          "required": false
        },
        {
          "name": "open",
          "type": "boolean | undefined",
          "description": "",
          "required": false
        },
        {
          "name": "defaultOpen",
          "type": "boolean | undefined",
          "description": "",
          "required": false
        },
        {
          "name": "dismissible",
          "type": "boolean | undefined",
          "description": "",
          "required": false
        }
      ]
    },
    "hook": {
      "members": [
        {
          "name": "defaultOpen",
          "type": "boolean | undefined",
          "description": "",
          "required": false
        }
      ]
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  }
}
