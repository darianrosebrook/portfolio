    "emptyState",
    "option",
    "check"
  ],
  "variants": {
    "size": [
      "sm",
      "md",
      "lg"
    ],
    "position": [
      "bottom",
      "top",
      "auto"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "active",
    "disabled",
    "open",
    "closed",
    "selected"
  ],
  "slots": {
    "content": {
      "required": false
    },
    "options": {
      "required": false
    },
    "search": {
      "required": false
    },
    "trigger": {
      "required": false
    }
  },
  "a11y": {
    "role": "combobox",
    "roles": [
      "combobox",
      "listbox",
      "option"
    ],
    "labeling": [
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "Enter|Space",
        "when": "trigger",
        "then": "activate"
      },
      {
        "key": "ArrowDown|ArrowUp",
        "when": "trigger",
        "then": "navigate options"
      },
      {
        "key": "Enter|Space",
        "when": "option",
        "then": "select option"
      },
      {
        "key": "Escape",
        "when": "listbox",
        "then": "close"
      }
    ],
    "apgPattern": "combobox"
  },
