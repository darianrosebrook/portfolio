        "key": "Enter|Space",
        "when": "trigger",
        "then": "activate"
      },
      {
        "key": "ArrowDown|ArrowUp",
        "when": "trigger",
        "then": "navigate options"
      },
      {
        "key": "Enter|Space",
        "when": "option",
        "then": "select option"
      },
      {
        "key": "Escape",
        "when": "listbox",
        "then": "close"
      }
    ],
    "apgPattern": "combobox"
  },
