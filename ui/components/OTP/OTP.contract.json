{
  "name": "OTP",
  "layer": "composer",
  "anatomy": [
    "root",
    "group",
    "field"
  ],
  "variants": {
    "mode": [
      "numeric",
      "alphanumeric"
    ]
  },
  "states": [
    "default",
    "focus",
    "disabled"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"otp\"]"
    },
    "group": {
      "required": false,
      "selector": "[data-slot=\"otp-group\"]"
    },
    "field": {
      "required": true,
      "selector": "[data-slot=\"otp-field\"]"
    },
    "label": {
      "required": false,
      "selector": "[data-slot=\"otp-label\"]"
    },
    "error": {
      "required": false,
      "selector": "[data-slot=\"otp-error\"]"
    },
    "separator": {
      "required": false,
      "selector": "[data-slot=\"otp-separator\"]"
    }
  },
  "a11y": {
    "role": "group",
    "roles": [
      "group",
      "alert"
    ],
    "labeling": [
      "aria-describedby",
      "aria-readonly",
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "KeyboardEvent",
        "when": "root",
        "then": "handled by component"
      }
    ],
    "apgPattern": null
  },
  "tokens": {
    "root": {
      "otp.color.background.default": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "otp.color.foreground.primary": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "otp.color.foreground.secondary": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "otp.color.border.default": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "property": "border-color",
        "layer": "semantic"
      },
      "otp.color.border.accent": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      },
      "otp.size.padding.default": {
        "resolvesTo": "core.spacing.size.07",
        "fallback": "24px",
        "property": "padding",
        "layer": "core"
      },
      "otp.size.radius.default": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "otp.elevation.default": {
        "resolvesTo": "semantic.elevation.default",
        "fallback": "[object Object]",
        "layer": "semantic"
      },
      "otp.overlay.imageOverlay": {
        "resolvesTo": "semantic.color.background.image.overlay",
        "fallback": "rgba(0, 0, 0, 0.5)",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "length",
          "type": "number | undefined",
          "description": "length prop for OTP.",
          "required": false
        },
        {
          "name": "mode",
          "type": "OTPGuardMode | undefined",
          "description": "mode prop for OTP.",
          "required": false
        },
        {
          "name": "value",
          "type": "string | undefined",
          "description": "value prop for OTP.",
          "required": false
        },
        {
          "name": "defaultValue",
          "type": "string | undefined",
          "description": "defaultValue prop for OTP.",
          "required": false
        },
        {
          "name": "disabled",
          "type": "boolean | undefined",
          "description": "disabled prop for OTP.",
          "required": false
        },
        {
          "name": "readOnly",
          "type": "boolean | undefined",
          "description": "readOnly prop for OTP.",
          "required": false
        },
        {
          "name": "title",
          "type": "string | undefined",
          "description": "title prop for OTP.",
          "required": false
        }
      ]
    },
    "passthrough": {
      "extends": "div"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "focus": {
    "strategy": "manual",
    "orientation": "horizontal",
    "initialFocus": "field",
    "wrap": false,
    "description": "Focus moves automatically to the next OTPField after a digit is entered, and to the previous field on Backspace. Arrow keys can also navigate between fields."
  },
  "relationships": [
    {
      "from": "root",
      "to": "label",
      "attribute": "aria-labelledby",
      "description": "The OTP group region is labelled by the OTPLabel element when present."
    },
    {
      "from": "root",
      "to": "error",
      "attribute": "aria-describedby",
      "when": "validity=invalid",
      "description": "The group references the error message region when in an invalid state."
    },
    {
      "from": "field",
      "to": "group",
      "attribute": "aria-label",
      "description": "Each individual input field carries an aria-label like 'Digit N of M' for screen reader enumeration."
    }
  ],
  "description": "One-time password input composed of individual single-character digit fields.",
  "a2ui": {
    "category": "form-field",
    "usageHints": [
      "Set length to control the number of digit fields",
      "Focus advances automatically after each digit is entered",
      "Compose with OTPLabel for the field label and OTPError for validation feedback",
      "Use OTPSeparator between fields for visual grouping (e.g., 3+3 pattern)"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "OTPInput",
        "OTPLabel",
        "OTPError",
        "OTPSeparator"
      ]
    }
  },
  "channels": {
    "value": {
      "description": "The full OTP string assembled from individual digit inputs.",
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onChange",
      "valueType": "string"
    }
  },
  "form": {
    "participates": true,
    "inputType": "text",
    "serialization": {
      "valueSource": "prop:value"
    },
    "validity": {
      "model": "native",
      "completionRequired": true
    }
  }
}
