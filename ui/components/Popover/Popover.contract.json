{
  "name": "Popover",
  "layer": "composer",
  "anatomy": [
    "root",
    "popoverContainer",
    "popoverTrigger",
    "popoverContent",
    "activeTrigger"
  ],
  "variants": {
    "placement": [
      "top",
      "bottom",
      "left",
      "right",
      "auto"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "leaving"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"popover\"]"
    },
    "trigger": {
      "required": true,
      "selector": "[data-slot=\"popover-trigger\"]"
    },
    "content": {
      "required": true,
      "selector": "[data-slot=\"popover-content\"]"
    }
  },
  "a11y": {
    "role": "region",
    "labeling": [
      "aria-haspopup"
    ],
    "keyboard": [
      {
        "key": "KeyboardEvent",
        "when": "root",
        "then": "handled by component"
      }
    ],
    "apgPattern": null
  },
  "tokens": {
    "root": {
      "popover.size.padding.default": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "padding",
        "layer": "core"
      },
      "popover.size.radius.default": {
        "resolvesTo": "semantic.shape.control.radius.default",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "semantic"
      },
      "popover.size.radius.full": {
        "resolvesTo": "core.shape.radius.full",
        "fallback": "9999px",
        "property": "border-radius",
        "layer": "core"
      },
      "popover.size.gap.default": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "gap",
        "layer": "core"
      },
      "popover.size.maxWidth.default": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "layer": "core"
      },
      "popover.color.background.content": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "popover.color.border.accent": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      },
      "popover.elevation.default": {
        "resolvesTo": "semantic.elevation.default",
        "fallback": "[object Object]",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "defaultOpen",
          "type": "boolean | undefined",
          "description": "Initial open state",
          "required": false
        },
        {
          "name": "closeOnOutsideClick",
          "type": "boolean | undefined",
          "description": "Close when clicking outside content",
          "required": false
        },
        {
          "name": "closeOnEscape",
          "type": "boolean | undefined",
          "description": "Close when pressing Escape",
          "required": false
        },
        {
          "name": "offset",
          "type": "number | undefined",
          "description": "offset prop for Popover.",
          "required": false,
          "default": 8
        },
        {
          "name": "placement",
          "type": "\"top\" | \"bottom\" | \"left\" | \"right\" | \"auto\" | undefined",
          "description": "placement prop for Popover.",
          "required": false,
          "default": "auto"
        },
        {
          "name": "triggerStrategy",
          "type": "\"click\" | \"hover\" | undefined",
          "description": "triggerStrategy prop for Popover.",
          "required": false,
          "default": "click"
        },
        {
          "name": "open",
          "type": "boolean | undefined",
          "description": "Controlled open state",
          "required": false
        },
        {
          "name": "anchor",
          "type": "HTMLElement | null | undefined",
          "description": "External anchor element to position against (bypasses Trigger)",
          "required": false
        }
      ]
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "Duration set to 0; popover appears/disappears instantly without animation.",
    "transitions": [
      {
        "name": "open",
        "trigger": "openness=closed\u2192open",
        "phase": "enter",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasizedOut"
      },
      {
        "name": "close",
        "trigger": "openness=open\u2192closed",
        "phase": "exit",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasizedIn"
      }
    ]
  },
  "focus": {
    "strategy": "none",
    "description": "Popover does not trap focus. Focus remains on the trigger or moves into the content if interactive children are present."
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "positioning": "anchored",
    "layering": "popover",
    "collision": "flip-shift"
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape",
        "defaultEnabled": true,
        "description": "Closes the popover and returns focus to the trigger."
      },
      {
        "event": "outsideClick",
        "defaultEnabled": true,
        "description": "Clicking outside the popover content or trigger closes the popover."
      }
    ]
  },
  "relationships": [
    {
      "from": "trigger",
      "to": "content",
      "attribute": "aria-controls",
      "when": "openness=open"
    },
    {
      "from": "trigger",
      "to": "content",
      "attribute": "aria-expanded",
      "when": "openness=open",
      "description": "aria-expanded is true when the popover is open, false when closed."
    }
  ],
  "channels": {
    "openness": {
      "description": "Whether the popover content is visible.",
      "value": "open",
      "onChange": "onOpenChange",
      "valueType": "boolean"
    }
  },
  "description": "Non-modal floating panel anchored to a trigger element. Does not trap focus.",
  "a2ui": {
    "category": "overlay",
    "usageHints": [
      "Use for supplemental, non-blocking information that does not require a decision",
      "Popover.Trigger wraps the element that opens the panel; Popover.Content is the floating panel",
      "Bind open and onOpenChange for controlled mode",
      "Prefer Tooltip for simple text-only hints; use Popover when content is interactive"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "Popover.Trigger",
        "Popover.Content"
      ]
    }
  }
}
